<odoo>
    <record id="view_move_form_inherit_bandera" model="ir.ui.view">
        <field name="name">account.move.form.inherit.bandera</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form" />
        <field name="arch" type="xml">
            <!-- Localiza el div/field donde está tu bandera original -->
            <xpath expr="//page[@name='other_info']//field[@name='delivery_date']" position="before">
                <field name="bandera"/>
            </xpath>
        </field>
    </record>
</odoo>