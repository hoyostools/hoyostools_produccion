<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="purchase_order_inherit_reception_validation_process_view" model="ir.ui.view">
        <field name="name">purchase.order.form.inherit.reception.validation.process</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='picking_type_id']" position="after">
                    <field name="approved_for_processing"/>
            </xpath>
        </field>
    </record>
</odoo>