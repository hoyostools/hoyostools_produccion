<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Primer bloque: Añade el campo Rentabilidad en la pestaña Información General -->
    <record id="view_product_template_form_profitability" model="ir.ui.view">
        <field name="name">product.template.form.profitability</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='detailed_type']" position="before">
                    <field name="profitability" readonly="1" />
            </xpath>
        </field>
    </record>

    <!-- Segundo bloque: Añade los campos Precio con 10% y Precio con 15% debajo de Rentabilidad -->
    <record id="view_product_template_form_prices" model="ir.ui.view">
        <field name="name">product.template.form.prices</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='profitability']" position="after">
                <field name="price_10" readonly="1" />
                <field name="price_15" readonly="1" />
                <field name="price_20" readonly="1" />
                <field name="price_30" readonly="1" />
                <field name="price_40" readonly="1" />
                <field name="price_50" readonly="1" />
            </xpath>
        </field>
    </record>
</odoo>
