<odoo>
    <!-- Tree View -->
    <record id="view_stock_return_request_tree" model="ir.ui.view">
        <field name="model">ht.stock.return.request</field>
        <field name="arch" type="xml">
            <tree
                decoration-muted="state=='cancel'"
                decoration-info="state=='draft'"
                decoration-danger="state=='confirmed'"
            >
                <field name="name"/>
                <field name="partner_id"/>
                <field name="pickup_address_id" context="{'default_type': 'delivery'}" groups="base.group_user"/>
                <field name="salesperson_id" readonly="1"/>
                <field name="return_from_location" groups="stock.group_stock_multi_locations"/>
                <field name="return_to_location" groups="stock.group_stock_multi_locations"/>
                <field name="return_type"/>
                <field name="has_credit_note"/>
                <field name="product_count"/>
                <field name="estimated_total" readonly="1"/>
                <field name="state"/>
                <field name="impresion"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_stock_return_request_form" model="ir.ui.view">
        <field name="model">ht.stock.return.request</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <!-- Confirmar -->
                    <button name="action_confirm"
                            invisible="state != 'draft'"
                            type="object"
                            string="Confirmar"
                            class="oe_highlight"/>

                    <!-- VALIDAR DESACTIVADO (removido) -->

                    <!-- Imprimir -->
                    <button name="do_print_return_request"
                            invisible="state not in ('confirmed', 'done')"
                            string="Imprimir"
                            type="object"/>

                    <!-- Set to Draft -->
                    <button name="action_cancel_to_draft"
                            invisible="state != 'cancel'"
                            string="Set to Draft"
                            type="object"/>

                    <!-- Cancelar (solo visible en draft) -->
                    <button name="action_cancel"
                            invisible="state != 'draft'"
                            string="Cancelar"
                            type="object"/>

                    <field name="state"
                           widget="statusbar"
                           statusbar_visible="draft,confirmed,done"/>
                </header>

                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <field name="returned_picking_ids" invisible="1"/>
                        <field name="invoice_ids" invisible="1"/>

                        <!-- Albaranes -->
                        <button name="action_view_pickings"
                                string="Albaranes"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-truck"
                                invisible="not returned_picking_ids"/>

                        <!-- Notas de Crédito -->
                        <button name="action_view_credit_notes"
                                string="Notas de Crédito"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-credit-card"
                                invisible="not invoice_ids">
                            <field name="invoice_ids" widget="statinfo"/>
                        </button>

                        <!-- Crear Nota de Crédito -->
                        <button name="action_create_credit_note"
                                type="object"
                                string="Crear Nota Crédito"
                                class="btn-primary"
                                invisible="state != 'done' or invoice_ids"/>
                    </div>

                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>

                    <!-- Campos -->
                    <group>
                        <group>
                            <field name="partner_id" required="return_type != 'internal'" invisible="return_type == 'internal'" readonly="state != 'draft'"/>
                            <field name="pickup_address_id" context="{'default_type': 'delivery'}" groups="base.group_user" readonly="state != 'draft'"/>
                            <field name="salesperson_id" readonly="1"/>
                            <field name="return_type" readonly="state != 'draft'"/>
                            <field name="return_order" readonly="state != 'draft'"/>
                            <field name="return_from_location" invisible="1"/>
                            <field name="return_to_location" invisible="1"/>
                            <field name="estimated_total" readonly="1"/>
                        </group>
                        <group>
                            <field name="from_date" readonly="state != 'draft'"/>
                            <field name="return_from_location" groups="stock.group_stock_multi_locations" readonly="state != 'draft'"/>
                            <field name="return_to_location" groups="stock.group_stock_multi_locations" readonly="state != 'draft'"/>
                            <field name="picking_types" widget="many2many_tags" readonly="state != 'draft'" options="{'no_create': True}"/>
                            <field name="impresion"/>
                        </group>
                    </group>

                    <!-- Productos a devolver -->
                    <notebook>
                        <page string="Productos a Devolver" name="return_lines">
                            <field name="line_ids" readonly="state != 'draft'">
                                <tree editable="bottom">
                                    <field name="product_id" string="Producto"/>
                                    <field name="lot_id"/>
                                    <field name="product_uom_id" string="Unidad de Medida"/>
                                    <field name="quantity" string="Cantidad"/>
                                    <field name="state_quality"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Comentarios">
                            <field name="note"/>
                        </page>
                        <page string="Otra información" name="other_info" invisible="return_type != 'customer'">
                            <group>
                                <field name="package_unit" readonly="state != 'draft'"/>
                                <field name="pickup_method" readonly="state != 'draft'"/>
                                <field name="invoice_reference" readonly="state != 'draft'"/>
                            </group>
                        </page>
                        <page string="Autorizaciones">
                            <group>
                                <field name="authorized" readonly="state != 'draft'"/>
                                <field name="no_validate_history" readonly="state != 'draft'"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Acción -->
    <record id="action_stock_return_request_tree" model="ir.actions.act_window">
        <field name="name">Solicitudes de devolución</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">ht.stock.return.request</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- Menú -->
    <menuitem id="menu_stock_return_request"
              name="Solicitudes de devolución"
              parent="sale.sale_order_menu"
              action="action_stock_return_request_tree"
              sequence="99"
              groups="stock.group_stock_user"/>
</odoo>
