<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_ap_anticipo_form" model="ir.ui.view">
        <field name="name">ap.anticipo.form</field>
        <field name="model">ap.anticipo</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <h1>
                        <field name="name" required="1"/>
                    </h1>
                    <group>
                        <group>
                            <field name="cuenta_anticipo_id" required="1"/>
                            <field name="internal_type_id" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_ap_anticipo_list" model="ir.ui.view">
        <field name="name">ap.anticipo.tree</field>
        <field name="model">ap.anticipo</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="cuenta_anticipo_id"/>
                <field name="internal_type_id"/>
            </tree>
        </field>
    </record>

    <record id="action_ap_anticipo" model="ir.actions.act_window">
        <field name="name">Anticipo Clientes</field>
        <field name="res_model">ap.anticipo</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>