<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Inherit Form View to Modify it -->
        <record model="ir.ui.view" id="product_template_form_view_discount">
            <field name="name">product.template.product.website.form</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="product.product_template_form_view"/>
            <field name="arch" type="xml">
                <!-- add state field in header -->
                <xpath expr="//page[@name='sales']/group[@name='sale']/group" position="before">
                    <group name="product_template_images" string="Descuentos" invisible="not sale_ok">
                        <group colspan="2">
                            <field name="valor_a"/>
                            <field name="valor_b"/>
                            <field name="descuento_rango"/>
                            <field name="descuento_mayor"/>
                        </group>

                        <group>
                            <group>
                                <field name="applicable_sale_order" string="Aplicable a Ventas"/>
                            </group>
                            <group>
                                <field name="applicable_web" string="Aplicable en Web" class="oe_inline"/>
                            </group>
                        </group>
                    </group>
                </xpath>
            </field>
        </record>
    </data>
</odoo>