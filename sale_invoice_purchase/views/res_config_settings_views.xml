<odoo>
    <record id="res_config_settings_view_form_inherit_auto_po" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.auto.po</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//app[@name='general_settings']" position="inside">
                <div class="app_settings_block" data-string="Sincronización de Compras" string="Sincronización de Compras">
                    <h2>Sincronización de Compras</h2>
                    <div class="row mt16 o_settings_container">
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane">
                                <field name="auto_create_po_from_invoice"/>
                            </div>
                            <div class="o_setting_right_pane">
                                <label for="auto_create_po_from_invoice"/>
                                <div class="text-muted">
                                    Si está activo, cada vez que se valide una factura de cliente, se creará automáticamente una orden de compra en las bases remotas configuradas.
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
