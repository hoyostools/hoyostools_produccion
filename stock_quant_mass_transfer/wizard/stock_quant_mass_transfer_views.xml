<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_stock_quant_mass_transfer_wizard" model="ir.ui.view">
        <field name="name">stock.quant.mass.transfer.wizard.form</field>
        <field name="model">stock.quant.mass.transfer.wizard</field>
        <field name="arch" type="xml">

            <form string="Trasladar Varios">

                <group>
                    <field name="picking_type_id"/>
                    <field name="validar_albaranes"/>
                    <field name="transfer_mode"/>
                    <field name="destination_location_id"
                           invisible="transfer_mode != 'same'"
                           required="transfer_mode == 'same'"/>
                </group>

                <field name="line_ids">

                    <tree editable="bottom">

                        <field name="product_id" force_save="1"/>
                        <field name="source_location_id" force_save="1"/>
                        <field name="available_qty" force_save="1"/>

                        <field name="destination_location_id"
                               invisible="parent.transfer_mode == 'same'"/>

                        <field name="quantity"/>

                    </tree>

                </field>

                <footer>
                    <button name="action_transfer"
                            string="Trasladar"
                            type="object"
                            class="btn-primary"/>

                    <button string="Cancelar"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>

            </form>

        </field>
    </record>

    <record id="action_stock_quant_mass_transfer_wizard"
            model="ir.actions.act_window">

        <field name="name">Trasladar Varios</field>
        <field name="res_model">stock.quant.mass.transfer.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>

    </record>

</odoo>