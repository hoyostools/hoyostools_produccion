<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_tax_form_inherit_base" model="ir.ui.view">
        <field name="name">account.tax.form.inherit.base</field>
        <field name="model">account.tax</field>
        <field name="inherit_id" ref="account.view_tax_form"/>
        <field name="arch" type="xml">
            <field name="is_base_affected" position="after">
                <field name="base_check"/>
                <field name="base_amount" invisible="not base_check"/>
                <field name="reteiva"/>
                <field name="impuesto_reteiva" invisible="not reteiva"/>
            </field>
        </field>
    </record>
</odoo>
