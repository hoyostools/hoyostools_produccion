<odoo>
    <record id="view_product_form_sync_image_api" model="ir.ui.view">
        <field name="name">product.template.form.sync.image.api</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button
                    name="action_sync_image_from_external_api"
                    type="object"
                    string="Sincronizar imagen desde API"
                    class="btn-primary"
                    icon="fa-cloud-download"
                />
            </xpath>
        </field>
    </record>
</odoo>