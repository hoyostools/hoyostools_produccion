<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- =========================
         TREE
    ========================== -->

    <record id="view_product_template_tree_consulta" model="ir.ui.view">
        <field name="name">product.template.tree.consulta</field>
        <field name="model">product.template</field>
        <field name="arch" type="xml">

            <tree string="Productos" create="0" edit="0" delete="0">

                <field name="image_128" string="Imagen" widget="image" options="{'size': [40, 40]}"/>
                <field name="default_code"/>
                <field name="name"/>
                <field name="barcode"/>

            </tree>

        </field>
    </record>

    <!-- =========================
         KANBAN
    ========================== -->

    <record id="view_product_template_kanban_consulta" model="ir.ui.view">
        <field name="name">product.template.kanban.consulta</field>
        <field name="model">product.template</field>
        <field name="arch" type="xml">

            <kanban>

                <field name="image_128" string="Imagen"/>

                <templates>

                    <t t-name="kanban-box">

                        <div class="oe_kanban_global_click o_kanban_record">

                            <div class="row">

                                <!-- IMAGEN -->

                                <div class="col-4 text-center">

                                    <field name="image_128"
                                        widget="image"
                                        class="oe_avatar"
                                        options="{'size': [80, 80]}"/>

                                </div>

                                <!-- INFO -->

                                <div class="col-8">

                                    <div>
                                        <strong>
                                            <field name="name"/>
                                        </strong>
                                    </div>

                                    <div>
                                        Ref:
                                        <field name="default_code"/>
                                    </div>

                                    <div>
                                        Barcode:
                                        <field name="barcode"/>
                                    </div>

                                </div>

                            </div>

                        </div>

                    </t>

                </templates>

            </kanban>

        </field>
    </record>

    <!-- =========================
         FORM
    ========================== -->

    <record id="view_product_template_form_consulta" model="ir.ui.view">
        <field name="name">product.template.form.consulta</field>
        <field name="model">product.template</field>
        <field name="arch" type="xml">

            <form string="Productos" create="0" edit="0" delete="0">

                <sheet>
                    <div class="oe_title text-center mb16">

                        <field name="image_1920" widget="image" class="oe_avatar" options="{'preview_image': 'image_1920', 'zoom': true}"/>

                    </div>

                    <notebook>

                        <page string="Información General">

                            <!-- CUADRO 1 -->

                            <group>

                                <group string="Información">

                                    <field name="default_code" readonly="1"/>
                                    <field name="barcode" readonly="1"/>
                                    <field name="cant_pack" readonly="1"/>

                                </group>

                                <group string="Información Producto">

                                    <field name="manufacturer_pref" readonly="1"/>
                                    <field name="product_brand_id" readonly="1"/>
                                    <field name="responsible_id" readonly="1"/>

                                </group>

                            </group>

                            <!-- CUADRO 2 -->

                            <group>

                                <group string="Descuentos">

                                    <field name="valor_a" readonly="1"/>
                                    <field name="valor_b" readonly="1"/>
                                    <field name="descuento_rango" readonly="1"/>
                                    <field name="descuento_mayor" readonly="1"/>

                                </group>

                                <group string="Inventario">

                                    <!-- Managers -->
                                    <field name="inventario_yumbo"
                                           readonly="1"
                                           groups="stock.group_stock_manager,__export__.res_groups_184_cee06de6,__export__.res_groups_175_a69b58cd"/>

                                    <field name="inventario_cali"
                                           readonly="1"
                                           groups="stock.group_stock_manager,__export__.res_groups_184_cee06de6"/>

                                    <field name="inventario_ptv"
                                           readonly="1"
                                           groups="stock.group_stock_manager,__export__.res_groups_184_cee06de6"/>

                                </group>

                            </group>

                            <!-- CUADRO 3 -->

                            <group string="Embalaje">

                                <field name="packaging_ids" readonly="1" options="{'no_create': True, 'no_edit': True, 'no_open': True}">

                                    <tree editable="bottom">
                                        <field name="name"/>
                                        <field name="qty"/>
                                        <field name="barcode"/>
                                    </tree>

                                </field>

                            </group>

                        </page>

                    </notebook>

                </sheet>

            </form>

        </field>
    </record>

    <!-- =========================
         ACTION
    ========================== -->
    <record id="action_productos_consulta" model="ir.actions.act_window">
        <field name="name">Productos</field>
        <field name="res_model">product.template</field>
        <field name="view_mode">tree,kanban,form</field>
    </record>

    <!-- TREE -->

    <record id="action_productos_consulta_tree" model="ir.actions.act_window.view">
        <field name="sequence" eval="1"/>
        <field name="view_mode">tree</field>
        <field name="view_id" ref="view_product_template_tree_consulta"/>
        <field name="act_window_id" ref="action_productos_consulta"/>
    </record>

    <!-- KANBAN -->

    <record id="action_productos_consulta_kanban" model="ir.actions.act_window.view">
        <field name="sequence" eval="2"/>
        <field name="view_mode">kanban</field>
        <field name="view_id" ref="view_product_template_kanban_consulta"/>
        <field name="act_window_id" ref="action_productos_consulta"/>
    </record>

    <!-- FORM -->

    <record id="action_productos_consulta_form" model="ir.actions.act_window.view">
        <field name="sequence" eval="3"/>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_product_template_form_consulta"/>
        <field name="act_window_id" ref="action_productos_consulta"/>
    </record>


    <!-- =========================
         MENU
    ========================== -->

    <menuitem
        id="menu_productos_consulta_root"
        name="Productos"
        web_icon="productos_consulta,static/description/icon.png"
        sequence="1"/>

    <menuitem
        id="menu_productos_consulta"
        name="Productos"
        parent="menu_productos_consulta_root"
        action="action_productos_consulta"
        sequence="1"/>

</odoo>