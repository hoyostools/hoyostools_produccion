<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_city_tree_inherit_costos_transportadora" model="ir.ui.view">
        <field name="name">res.city.tree.inherit.costos.transportadora</field>
        <field name="model">res.city</field>
        <field name="inherit_id" ref="base_address_extended.view_city_tree"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='state_id']" position="after">
                <field name="code" column_invisible="1"/>
                <field name="ciudad_principal"/>
                <field name="transportadora_id" />
                <field name="valor_caja"/>
            </xpath>

        </field>
    </record>

</odoo>
