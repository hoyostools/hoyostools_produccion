<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="res_config_settings_view_form_inherit_transportadora"
            model="ir.ui.view">
        <field name="name">res.config.settings.view.form.transportadora</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="sale.res_config_settings_view_form"/>
        <field name="arch" type="xml">

            <xpath expr="//setting[@id='discount_sale_order_lines']" position="before">
                <setting string="Presupuesto Transportadora Regional"
                        help="Porcentaje destinado a transporte para ciudades no principales.">
                    <field name="presupuesto_transportadora_regional"/>
                </setting>

                <setting string="Presupuesto Transportadora Principal"
                        help="Porcentaje destinado a transporte para ciudades principales.">
                    <field name="presupuesto_transportadora_principal"/>
                </setting>
            </xpath>

        </field>
    </record>

</odoo>
