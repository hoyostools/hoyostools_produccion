<odoo>
    <!-- VISTA TREE -->
    <record id="view_seguimiento_almacenamiento_tree" model="ir.ui.view">
        <field name="name">seguimiento.almacenamiento.tree</field>
        <field name="model">productividad.seguimiento_almacenamiento</field>
        <field name="arch" type="xml">
            <tree>
                <field name="user_id"/>
                <field name="fecha"/>
                <field name="puntos"/>
                <field name="cumplimiento_puntos" widget="progressbar"/>
                <field name="items"/>
                <field name="cumplimiento_items" widget="progressbar"/>
                <field name="documentos"/>
                <field name="cumplimiento_documentos" widget="progressbar"/>
            </tree>
        </field>
    </record>

    <!-- VISTA KANBAN -->
    <record id="view_seguimiento_almacenamiento_kanban" model="ir.ui.view">
        <field name="name">seguimiento.almacenamiento.kanban</field>
        <field name="model">productividad.seguimiento_almacenamiento</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_small_column" create="false">
                <field name="user_id"/>
                <field name="fecha"/>
                <field name="puntos"/>
                <field name="items"/>
                <field name="documentos"/>
                <field name="cumplimiento_puntos"/>
                <field name="cumplimiento_items"/>
                <field name="cumplimiento_documentos"/>
                <field name="meta_puntos_diarios"/>
                <field name="meta_items_diarios"/>
                <field name="meta_documentos_diarios"/>
                <field name="gestion_total"/>

                <templates>
                    <t t-name="kanban-box">
                        <div class="o_kanban_record">
                            <div style="text-align:center; height: 190px; padding: 10px;">
                                <t t-if="record.user_id.raw_value">
                                    <img t-att-src="'/web/image/res.users/' + record.user_id.raw_value + '/image_1024'" class="img img-fluid rounded-circle" style="height:150px; width:120px; object-fit:cover;"/>
                                </t>
                                <h4><t t-esc="record.user_id.value"/></h4>
                                <div><small><t t-esc="record.fecha.value"/></small></div>
                            </div>
                            <table class="table table-sm mt-2" style="font-size: 12px; margin: auto;">
                                <thead>
                                    <tr>
                                        <th></th>
                                        <th style="text-align:center;">Docs</th>
                                        <th style="text-align:center;">Items</th>
                                        <th style="text-align:center;">Puntos</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td><b>🎯 Metas</b></td>
                                        <td style="text-align:center;"><t t-esc="record.meta_documentos_diarios.value"/></td>
                                        <td style="text-align:center;"><t t-esc="record.meta_items_diarios.value"/></td>
                                        <td style="text-align:center;"><t t-esc="record.meta_puntos_diarios.value"/></td>
                                    </tr>
                                    <tr>
                                        <td><b>📊 Logros</b></td>
                                        <td style="text-align:center;"><t t-esc="record.documentos.value"/></td>
                                        <td style="text-align:center;"><t t-esc="record.items.value"/></td>
                                        <td style="text-align:center;"><t t-esc="record.puntos.value"/></td>
                                    </tr>
                                    <tr>
                                        <td><b>✅ %</b></td>
                                        <td style="text-align:center;"><t t-esc="record.cumplimiento_documentos.value"/>%</td>
                                        <td style="text-align:center;"><t t-esc="record.cumplimiento_items.value"/>%</td>
                                        <td style="text-align:center;"><t t-esc="record.cumplimiento_puntos.value"/>%</td>
                                    </tr>
                                    <tr>
                                        <td><b>🗂️ Gestión Total</b></td>
                                        <td colspan="3" style="text-align:center;"><t t-esc="record.gestion_total.value"/></td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- SEARCH -->
    <record id="view_seguimiento_almacenamiento_search" model="ir.ui.view">
        <field name="name">seguimiento.almacenamiento.search</field>
        <field name="model">productividad.seguimiento_almacenamiento</field>
        <field name="arch" type="xml">
            <search>
                <field name="user_id"/>
                <field name="fecha"/>
                <filter name="filter_today" string="Hoy" domain="[('fecha', '=', context_today())]"/>
                <filter name="filter_week" string="Esta semana" domain="[('fecha', '>=', (context_today() - datetime.timedelta(days=context_today().weekday())))]"/>
            </search>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_seguimiento_almacenamiento" model="ir.actions.act_window">
        <field name="name">Seguimiento Almacenamiento</field>
        <field name="res_model">productividad.seguimiento_almacenamiento</field>
        <field name="view_mode">kanban,tree</field>
        <field name="search_view_id" ref="view_seguimiento_almacenamiento_search"/>
    </record>

</odoo>
