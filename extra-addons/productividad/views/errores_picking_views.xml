<odoo>
    <record id="view_errores_picking_form" model="ir.ui.view">
        <field name="name">errores.picking.form</field>
        <field name="model">productividad.errores_picking</field>
        <field name="arch" type="xml">
            <form string="Errores en Picking">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_confirmar" type="object"
                                string="Confirmar" class="btn-primary"
                                invisible = "estado == 'confirmado'"/>
                        <field name="estado" widget="statusbar" statusbar_visible="borrador,confirmado"/>
                    </div>
                    <group>
                        <field name="sale_order_id" domain="[('state','=','sale'), ('invoice_ids','=',False)]"/>
                    </group>
                    <group>
                        <field name="linea_error_ids">
                            <tree editable="bottom">
                                <field name="product_id"/>
                                <field name="product_uom_qty"/>
                                <field name="tipo_novedad"/>
                                <field name="responsable" readonly="1"/>
                            </tree>
                        </field>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_errores_picking_tree" model="ir.ui.view">
        <field name="name">errores.picking.list</field>
        <field name="model">productividad.errores_picking</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="sale_order_id"/>
                <field name="estado"/>
            </tree>
        </field>
    </record>

    <record id="action_errores_picking" model="ir.actions.act_window">
        <field name="name">Errores Picking</field>
        <field name="res_model">productividad.errores_picking</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>
