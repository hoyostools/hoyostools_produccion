<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_account_account_form_retencion" model="ir.ui.view">
        <field name="name">account.account.form.retencion</field>
        <field name="model">account.account</field>
        <field name="inherit_id" ref="account.view_account_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='accounting']/group" position="inside">
                <group string="Reporte de retención">
                    <field name="visible_reporte_retencion"/>
                </group>
            </xpath>

        </field>
    </record>

</odoo>
