<odoo>
  <record id="view_stock_quant_search_exact_ref" model="ir.ui.view">
    <field name="name">stock.quant.search.exact.ref</field>
    <field name="model">stock.quant</field>
    <field name="inherit_id" ref="stock.quant_search_view"/>
    <field name="arch" type="xml">
      <xpath expr="//search/field[@name='product_id']" position="before">
        <field name="product_id" string="Referencia Interna Exacta" filter_domain="[('product_id.default_code', '=', self)]"/>
      </xpath>
    </field>
  </record>
</odoo>
