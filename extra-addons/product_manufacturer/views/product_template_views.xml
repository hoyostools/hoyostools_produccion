<?xml version="1.0" encoding="utf-8"?>
<odoo>

        <record id="view_product_template_form_manufacturer" model="ir.ui.view">
            <field name="name">product.template.form.manufacturer</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="product.product_template_only_form_view"/>
            <field name="arch" type="xml">

                <xpath expr="//sheet/notebook/page[1]" position="inside">

                    <group string="FABRICANTE">

                        <group>
                            <field name="manufacturer_id" options="{'no_create': True, 'no_open': True}"/>
                            <field name="manufacturer_pname"/>
                        </group>

                        <group>
                            <field name="manufacturer_pref"/>
                            <field name="manufacturer_purl" widget="url"/>
                        </group>

                    </group>

                </xpath>

            </field>
        </record>

</odoo>