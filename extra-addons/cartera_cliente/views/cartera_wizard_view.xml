<odoo>
    <record id="view_cartera_wizard_form" model="ir.ui.view">
        <field name="name">cartera.cliente.wizard.form</field>
        <field name="model">cartera.cliente.wizard</field>
        <field name="arch" type="xml">
            <form string="Cartera de Cliente">
                <group>
                    <field name="partner_id"/>

                    <field name="opcion_reporte"/>

                    <field name="fecha_vencimiento" 
                           invisible="opcion_reporte != 'fecha_vencimiento'"
                           required="opcion_reporte == 'fecha_vencimiento'"/>
                </group>

                <footer>
                    <button name="generar_reporte" string="Generar" type="object" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
