<?xml version="1.0" encoding="UTF-8"?>
<!--Add Barcode in Shop Session Screen-->
<templates id="template" xml:space="preserve">
    <t t-name="point_of_sale.ProductCard" t-inherit="point_of_sale.ProductCard"
       t-inherit-mode="extension">
        <xpath expr="//div[hasclass('product-content')]/span[hasclass('price-tag')]"
               position="before">
            <span style="word-wrap: break-word;">
                <t t-if="this.env.services.pos.db.product_by_id[props.productId].barcode">
                <t t-esc="this.env.services.pos.db.product_by_id[props.productId].barcode"/>
                </t>

                 </span>
        </xpath>
       </t>
</templates>