<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_multi_invoice_payment_wizard" model="ir.ui.view">
        <field name="name">multi.invoice.payment.wizard.form</field>
        <field name="model">multi.invoice.payment.wizard</field>
        <field name="arch" type="xml">

            <form string="Pago de facturas múltiples">

                <group>
                    <group>
                        <field name="journal_id"/>
                        <field
                            name="payment_type"
                            widget="radio"
                            options="{'horizontal': true}"
                        />
                        <field name="payment_method_line_id"/>
                    </group>

                    <group>
                        <field name="payment_date"/>
                        <field name="difference_amount" readonly="1"/>
                    </group>
                </group>

                <field name="line_ids">

                    <tree editable="bottom" create="false">

                        <field name="move_id_int" column_invisible="1"/>
                        <field name="partner_id_int" column_invisible="1"/>

                        <field name="move_id" readonly="1" options="{'no_open': True}"/>
                        <field name="partner_id" readonly="1" options="{'no_open': True}"/>
                        <field name="invoice_amount" readonly="1" sum="Total"/>
                        <field name="residual_amount" readonly="1"/>
                        <field name="receive_amount"/>

                    </tree>

                </field>

                <footer>
                    <button
                        string="Validar"
                        type="object"
                        name="action_validate"
                        class="btn-primary"
                    />

                    <button
                        string="Cancelar"
                        special="cancel"
                    />
                </footer>

            </form>

        </field>
    </record>

    <record id="action_multi_invoice_payment_wizard" model="ir.actions.act_window">
        <field name="name">Pago de facturas múltiples</field>
        <field name="res_model">multi.invoice.payment.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>