<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="productivity_dashboard_template" owl="1">
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/css/bootstrap.min.css"/>
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/js/bootstrap.bundle.min.js"></script>
        <div style="justify-content: center; padding: 3.5em; padding-top:10px; overflow-y:scroll;height:100%;">
            <style>
                table tbody tr:nth-child(odd) {
                    background-color: #d3d3d3; /* Gris claro */
                }
                table tbody tr:nth-child(even) {
                    background-color: #a9a9a9; /* Gris oscuro */
                }
                .square-image {
                    width: 80px;
                    height: 80px;
                    aspect-ratio: 1 / 1;
                    object-fit: cover;
                    border-radius: 8px; /* Opcional: para bordes redondeados */
                }
                .selected-tags {
                    display: flex;
                    flex-wrap: wrap;
                    gap: 5px;
                }

                .tag {
                    display: inline-flex;
                    align-items: center;
                    background-color: #007bff;
                    color: white;
                    padding: 5px 10px;
                    border-radius: 15px;
                    font-size: 0.9em;
                    cursor: default;
                }

                .tag .remove-tag {
                    background: none;
                    border: none;
                    color: white;
                    margin-left: 10px;
                    font-weight: bold;
                    cursor: pointer;
                }

                .tag .remove-tag:hover {
                    color: #ffcccc;
                }
            </style>
            <div class="text-center title" style="color: #01579b">
                <strong><h1>TABLERO DE PRODUCTIVIDAD</h1></strong>
            </div>
            <hr/>
            <br/>
            <div id="selected-tags" class="selected-tags justify-center" style="width:100%; border:0px"></div>
            <br/>
            <div class="row borderless text-center" style="justify-content: center">

                Rango de fechas:
                <select id="date_filter_select" t-on-change="filterByDate" style="width:20%;height:10%; border:0px">
                    <option value="today" selected="True">Hoy</option>
                    <option value="this_week">Esta Semana</option>
                    <option value="this_month">Este Mes</option>
                    <option value="custom">Fecha específica</option>
                </select>

                <input type="date" id="custom_date" t-att-disabled="state.disable_custom_date"
                       t-on-change="filterByCustomDate" style="width:25%; height:10%; border:0px; margin-left: 10px; display: true;"/>

                Empleado:
                <select class="form-multi-select empleado_select" id="empleado_select" place-holder="Seleccione.." style="margin-left: 10px;width:25%; border:0px">
                    <option value="todos">Todos</option>
                    <t t-foreach="state.valores_empleados_selection" t-as="empleado" t-key="empleado.id">
                        <option t-att-value="empleado.id"><strong><t t-esc="empleado.user_id[1]"/></strong></option>
                    </t>
                </select>
                <select class="form-multi-select empleado_select2" id="empleado_select2" placeholder="Seleccione..." t-on-change="captureChange" multiple="" style="height:0; visibility: hidden !important; margin-left: 10px;width:25%; border:0px">
                    <!-- Las opciones seleccionadas en el primer select se agregan aquí -->
                </select>

            </div>
            <br/>
            <br/>
            <div class="row" style="position:sticky;">
                <nav>
                    <div class="nav nav-tabs nav-pills justify-content-center pestania" id="nav-tab" style="margin-botom: 0px !important" role="tablist">
                        <a class="nav-item nav-link active show fade h5" id="nav-empleados-tab" data-toggle="tab" aria-current="page" href="#nav-empleados" role="tab" aria-controls="nav-empleados" aria-selected="true">Empleados</a>
                        <a class="nav-item nav-link show fade h5" id="nav-documentos-tab" data-toggle="tab" href="#nav-documentos" role="tab" aria-controls="nav-documentos" aria-selected="false">Documentos</a>
                    </div>
                </nav>
            </div>
            <div class="tab-content">
                <div class="tab-pane active" id="nav-empleados" role="tabpanel" aria-labelledby="nav-empleados-tab">
                    <div id="chartdiv" class="row" style="width:100%; height:400px"></div>
                </div>
                <div class="tab-pane" id="nav-documentos" role="tabpanel" aria-labelledby="nav-documentos-tab">
                    <div id="chartdiv2" class="row" style="width:100%; height:400px"></div>
                </div>
            </div>
            <script>
                $(document).ready(function(){
                    $(".pestania a").on('click', function(evt){
                        evt.preventDefault();
                        $(this).tab("show")
                    })
                });
            </script>
            <br/>
            <hr/>
            <br/>
            <div class="row">
                <table class="shadow col-md-2 table table-bordered"
                       style="width:45%; margin-right:20px;margin-left:30px;">
                    <thead style="background-color: gray; color: white;">
                        <tr style="font-size: 20px">
                            <th class="text-center" colspan="5"> <strong>PROGRESO ACTUAL DE LA OPERACIÓN</strong></th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr style="background-color: black; color: white">
                           <td><strong>ETAPA</strong></td>
                            <td><strong>DOCUMENTOS</strong></td>
                            <td><strong>PRODUCTOS</strong></td>
                            <td><strong>VALOR</strong></td>
                            <td><strong>% Operación</strong></td>
                        </tr>
                        <tr style="background-color: black; color: #CBC3E3">
                            <td>Total Ordenes de venta odoo</td>
                            <td><t t-esc="state.ordenes"/></td>
                            <td><t t-esc="state.productos_ordenes"/></td>
                            <td>$<t t-esc="state.sumar_ordenes"/></td>
                            <t t-if="state.cumplimiento_porcentajes &lt; 50">
                                <td rowspan="5"
                                    style="background-color: red; color: white; font-size: 35px; text-align: center; vertical-align: middle;">
                                        <strong><t t-esc="state.cumplimiento_porcentajes"/>%</strong>
                                </td>
                            </t>
                            <t t-if="state.cumplimiento_porcentajes &gt; 50 and state.cumplimiento_porcentajes &lt; 100">
                                <td rowspan="5"
                                    style="background-color: #FFC300; color: black; font-size: 35px; text-align: center; vertical-align: middle;">
                                        <strong><t t-esc="state.cumplimiento_porcentajes"/>%</strong>
                                </td>
                            </t>
                            <t t-if="state.cumplimiento_porcentajes == 100">
                                <td rowspan="5"
                                    style="background-color: green; color: black; font-size: 35px; text-align: center; vertical-align: middle;">
                                        <strong><t t-esc="state.cumplimiento_porcentajes"/>%</strong>
                                </td>
                            </t>
                        </tr>
                        <tr style="background-color: black; color: pink">
                            <td>Ordenes de venta por asignar</td>
                            <td><t t-esc="state.ordenes_asignar"/></td>
                            <td><t t-esc="state.productos_ordenes_asignar"/></td>
                            <td>$<t t-esc="state.sumar_ordenes_asignadas"/></td>
                        </tr>
                        <tr style="background-color: black; color: lightblue">
                            <td>Ordenes de venta por procesar</td>
                            <td><t t-esc="state.ordenes_procesar"/></td>
                            <td><t t-esc="state.productos_ordenes_procesar"/></td>
                            <td>$<t t-esc="state.sumar_ordenes_procesar"/></td>
                        </tr>
                        <tr style="background-color: black; color: lightgreen">
                            <td>Ordenes de venta procesadas</td>
                            <td><t t-esc="state.ordenes_procesadas"/></td>
                            <td><t t-esc="state.productos_ordenes_procesadas"/></td>
                            <td>$<t t-esc="state.sumar_ordenes_procesadas"/></td>
                        </tr>
                        <tr style="background-color: black; color: white">
                            <td>% Cumplimiento</td>
                            <td><t t-esc="state.cumplimiento"/>%</td>
                            <td><t t-esc="state.cumplimiento_productos"/>%</td>
                            <td><t t-esc="state.cumplimiento_valor"/>%</td>
                        </tr>

                    </tbody>
                </table>
                <div class="tab-content" style="height: 295px; width: 50%; overflow-y: auto;">
                    <nav>
                        <div class="nav nav-tabs nav-pills justify-content-center pestania_selected" id="nav-tab-empleados" style="margin-botom: 0px !important" role="tablist">
                            <a class="nav-item nav-link active show fade h5" id="nav-empleados-datos" data-toggle="tab" aria-current="page" href="#nav-datos" role="tab" aria-controls="nav-datos" aria-selected="true">Cumplimiento</a>
                            <a class="nav-item nav-link show fade h5" id="nav-empleados-tiempo" data-toggle="tab" href="#nav-tiempo" role="tab" aria-controls="nav-tiempo" aria-selected="false">Tiempo</a>
                            <a class="nav-item nav-link show fade h5" id="nav-empleados-errores" data-toggle="tab" href="#nav-errores" role="tab" aria-controls="nav-errores" aria-selected="false">Errores</a>
                        </div>
                    </nav>
                    <div class="tab-pane active" id="nav-datos" role="tabpanel" aria-labelledby="nav-datos">
                        <table class="table table-bordered" style="width: 100%; border-collapse: collapse;">
                        <thead style="background-color: black; color: white; position: sticky; top: 0; z-index: 2;">
                            <tr>
                                <th class="text-center"><strong>Usuario</strong></th>
                                <th class="text-center"><strong>(%)Cumplimiento</strong></th>
                                <th class="text-center"><strong>Función</strong></th>
                                <th class="text-center"><strong>Documentos</strong></th>
                                <th class="text-center"><strong>Productos</strong></th>
                                <th class="text-center"><strong>Valor</strong></th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="state.valores_empleados" t-as="empleado" t-key="empleado.id">
                                <tr style="font-size:13px">
                                    <t t-if="empleado.productos &gt; 0">
                                        <t t-set="cumplimiento_productos"
                                           t-value="Math.round((empleado.productos_procesado / empleado.productos ) *100)"/>
                                    </t>
                                    <t t-if="empleado.productos == 0">
                                        <t t-set="cumplimiento_productos" t-value="0"/>
                                    </t>
                                    <t t-if="empleado.valor_real &gt; 0">
                                        <t t-set="cumplimiento_valor"
                                           t-value="Math.round((empleado.valor_procesado_real / empleado.valor_real)*100)"/>
                                    </t>
                                    <t t-else="">
                                        <t t-set="cumplimiento_valor" t-value="0"/>
                                    </t>
                                    <t t-set="cumplimiento_promedio"
                                       t-value="Math.round((cumplimiento_valor + empleado.cumplimiento + cumplimiento_productos) / 3)"/>
                                    <t t-if="empleado.funcion.includes('montacargas')">
                                        <t t-set="cumplimiento_promedio"
                                           t-value="Math.round(cumplimiento_productos)"/>
                                    </t>
                                    <td><t t-esc="empleado.user_id[1]"/></td>
                                    <t t-if="cumplimiento_promedio &lt; 50">
                                        <td style="background-color : red;color:white"><t t-esc="cumplimiento_promedio"/>
                                            %</td>
                                    </t>
                                    <t t-if="cumplimiento_promedio &gt; 49 and cumplimiento_promedio &lt; 100">
                                        <td style="background-color : gold"><t t-esc="cumplimiento_promedio"/>
                                            %</td>
                                    </t>
                                    <t t-if="cumplimiento_promedio == 100">
                                        <td style="background-color : green"><t t-esc="cumplimiento_promedio"/>
                                            %</td>
                                    </t>
                                    <td><t t-esc="empleado.funcion"/></td>
                                    <td><t t-esc="empleado.documentos"/></td>
                                    <td><t t-esc="empleado.productos"/></td>
                                    <td><t t-esc="empleado.valor"/></td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                    </div>
                    <div class="tab-pane" id="nav-tiempo" role="tabpanel" aria-labelledby="nav-tiempo">
                        <table class="table table-bordered" style="width: 100%; border-collapse: collapse;">
                        <thead style="background-color: black; color: white; position: sticky; top: 0; z-index: 2;">
                            <tr>
                                <th class="text-center"><strong>Usuario</strong></th>
                                <th class="text-center"><strong>Tiempo promedio</strong></th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="state.valores_empleados" t-as="empleado" t-key="empleado.id">
                                <tr style="font-size:13px">
                                    <td><t t-esc="empleado.user_id[1]"/></td>
                                    <td><t t-esc="empleado.tiempo_promedio"/></td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                    </div>
                    <div class="tab-pane" id="nav-errores" role="tabpanel" aria-labelledby="nav-errores">
                        <table class="table table-bordered" style="width: 100%; border-collapse: collapse;">
                        <thead style="background-color: black; color: white; position: sticky; top: 0; z-index: 2;">
                            <tr>
                                <th class="text-center"><strong>Usuario</strong></th>
                                <th class="text-center"><strong>Sobrante</strong></th>
                                <th class="text-center"><strong>Faltante</strong></th>
                                <th class="text-center"><strong>Trocado</strong></th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="state.valores_empleados" t-as="empleado" t-key="empleado.id">
                                <tr style="font-size:13px">
                                    <td><t t-esc="empleado.user_id[1]"/></td>
                                    <td><t t-esc="0"/></td>
                                    <td><t t-esc="0"/></td>
                                    <td><t t-esc="0"/></td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                    </div>
                    <script>
                        $(document).ready(function(){
                            $(".pestania_selected a").on('click', function(evt){
                                evt.preventDefault();
                                $(this).tab("show")
                            })
                        });
                    </script>
                </div>
            </div>
            <br/>
            <div class="row">

            <t t-set="contador" t-value="1"/>

            <t t-set="grupo_otro_mostrado" t-value="false"/>
            <t t-set="grupo_empaque_mostrado" t-value="false"/>
            <t t-set="grupo_montacargas_mostrado" t-value="false"/>


            <!-- ================= SEPARADORES ================= -->

            <t t-foreach="state.valores_empleados" t-as="empleado" t-key="'otros_'+empleado.id">

            <t t-if="!(empleado.funcion &amp;&amp; (empleado.funcion.toLowerCase().includes('empaque') || empleado.funcion.toLowerCase().includes('montacargas')))">

            <t t-if="!grupo_otro_mostrado">

            <div class="col-12">
            <h3 style="color:#01579b;">
            <strong>FUNCION: SEPARADORES</strong>
            </h3>
            <hr/>
            </div>

            <t t-set="grupo_otro_mostrado" t-value="true"/>

            </t>


            <div class="col-md-4 col-sm-6 mb-4 d-flex align-items-stretch">

            <div class="border border-2 card shadow borderless w-100"
            style="border:0px;background-color:#25333e !important;color:white">

            <t t-esc="contador"/>


            <div class="card-body rounded"
            style="padding-right: calc(var(--gutter-x)* .3);
            padding-left: calc(var(--gutter-x)* .3);
            padding-top: calc(var(--gutter-y)* .1);
            padding-bottom: calc(var(--gutter-y)* .0);
            background-color:#25333e !important;">


            <div class="row"
            style="padding-right: calc(var(--gutter-x)* .1);
            padding-left: calc(var(--gutter-x)* .1);
            display:flex !important">


            <div class="col"
            style="padding-right: calc(var(--gutter-x)* .1);
            padding-left: calc(var(--gutter-x)* .1);
            flex:auto !important;
            width:20% !important">

            <img class="square-image col rounded mb-3 pd-2"
            t-attf-src="data:image/jpg;base64,#{empleado.image_1920}"
            style="width:80px;height:80px;object-fit:cover;aspect-ratio:1/1;"/>

            </div>


            <div class="col"
            style="padding-right: calc(var(--gutter-x)* .1);
            padding-left: calc(var(--gutter-x)* .1);
            flex:auto !important;
            width:80% !important">


            <table class="table table-borderless"
            style="font-size:13px;color:white">

            <thead>

            <tr>
            <td style="padding:0px;">Etapa</td>
            <td style="padding:0px;">Documentos</td>
            <td style="padding:0px;">Productos</td>
            <td style="padding:0px;">Valor</td>
            </tr>

            </thead>


            <tbody>


            <tr style="background-color:#25333e;">
            <td style="padding:0px;color:#CBC3E3">Asignación Odoo</td>
            <td style="padding:0px;"><t t-esc="empleado.documentos"/></td>
            <td style="padding:0px;"><t t-esc="empleado.productos"/></td>
            <td style="padding:0px;">$<t t-esc="empleado.valor"/></td>
            </tr>


            <tr style="background-color:#25333e;">
            <td style="padding:0px;color:lightblue">En Proceso</td>
            <td style="padding:0px;"><t t-esc="empleado.en_proceso"/></td>
            <td style="padding:0px;"><t t-esc="empleado.productos_en_proceso"/></td>
            <td style="padding:0px;">$<t t-esc="empleado.valor_en_proceso"/></td>
            </tr>


            <tr style="background-color:#25333e;">
            <td style="padding:0px;color:lightgreen">Procesado</td>
            <td style="padding:0px;"><t t-esc="empleado.procesado"/></td>
            <td style="padding:0px;"><t t-esc="empleado.productos_procesado"/></td>
            <td style="padding:0px;">$<t t-esc="empleado.valor_procesado"/></td>
            </tr>


            <tr style="background-color:#25333e;">

            <td style="padding:0px;">% Cumplimiento</td>


            <t t-if="empleado.cumplimiento &lt; 50">
            <td style="padding:0px;color:red;">
            <t t-esc="empleado.cumplimiento"/> %
            </td>
            </t>


            <t t-if="empleado.cumplimiento &gt; 49 &amp;&amp; empleado.cumplimiento &lt; 100">
            <td style="padding:0px;color:gold">
            <t t-esc="empleado.cumplimiento"/> %
            </td>
            </t>


            <t t-if="empleado.cumplimiento == 100">
            <td style="padding:0px;color:green">
            <t t-esc="empleado.cumplimiento"/> %
            </td>
            </t>


            <t t-if="empleado.productos &gt; 0">
            <t t-set="cumplimiento_productos"
            t-value="Math.round((empleado.productos_procesado / empleado.productos ) *100)"/>
            </t>


            <t t-if="empleado.productos == 0">
            <t t-set="cumplimiento_productos" t-value="0"/>
            </t>


            <t t-if="cumplimiento_productos &lt; 50">
            <td style="padding:0px;color:red;">
            <t t-esc="cumplimiento_productos"/> %
            </td>
            </t>


            <t t-if="cumplimiento_productos &gt; 49 &amp;&amp; cumplimiento_productos &lt; 100">
            <td style="padding:0px;color:gold">
            <t t-esc="cumplimiento_productos"/> %
            </td>
            </t>


            <t t-if="cumplimiento_productos == 100">
            <td style="padding:0px;color:green">
            <t t-esc="cumplimiento_productos"/> %
            </td>
            </t>


            <t t-if="empleado.valor_real &gt; 0">
            <t t-set="cumplimiento_valor"
            t-value="Math.round((empleado.valor_procesado_real / empleado.valor_real)*100)"/>
            </t>


            <t t-else="">
            <t t-set="cumplimiento_valor" t-value="0"/>
            </t>


            <t t-if="cumplimiento_valor &lt; 50">
            <td style="padding:0px;color:red;">
            <t t-esc="cumplimiento_valor"/> %
            </td>
            </t>


            <t t-if="cumplimiento_valor &gt; 49 &amp;&amp; cumplimiento_valor &lt; 100">
            <td style="padding:0px;color:gold">
            <t t-esc="cumplimiento_valor"/> %
            </td>
            </t>


            <t t-if="cumplimiento_valor == 100">
            <td style="padding:0px;color:green">
            <t t-esc="cumplimiento_valor"/> %
            </td>
            </t>

            </tr>


            <tr style="background-color:#25333e;">

            <td style="padding:0px;">Hora Primer Pedido</td>

            <td style="padding:0px;">
            <t t-esc="empleado.hora_inicio"/>
            </td>


            <t t-set="cumplimiento_promedio"
            t-value="Math.round((cumplimiento_valor + empleado.cumplimiento + cumplimiento_productos) / 3)"/>


            <t t-if="cumplimiento_promedio &lt; 50">

            <td rowspan="2" colspan="2"
            style="padding:0px;background-color:red;text-align:center;vertical-align:middle;">

            <t t-esc="cumplimiento_promedio"/> %

            </td>

            </t>


            <t t-if="cumplimiento_promedio &gt; 49 &amp;&amp; cumplimiento_promedio &lt; 100">

            <td rowspan="2" colspan="2"
            style="padding:0px;background-color:gold;text-align:center;vertical-align:middle;">

            <t t-esc="cumplimiento_promedio"/> %

            </td>

            </t>


            <t t-if="cumplimiento_promedio == 100">

            <td rowspan="2" colspan="2"
            style="padding:0px;background-color:green;text-align:center;vertical-align:middle;">

            <t t-esc="cumplimiento_promedio"/> %

            </td>

            </t>

            </tr>


            <tr style="background-color:#25333e;">

            <td style="padding:0px;">Hora Último Pedido</td>

            <td style="padding:0px;">
            <t t-esc="empleado.hora_fin"/>
            </td>

            </tr>


            </tbody>

            </table>

            </div>

            </div>

            </div>


            <div class="card-footer">

            <strong style="font-size:12px;">
            <t t-esc="empleado.user_id[1]"/>
            </strong>

            <strong style="float:right;font-size:14px;">
            Función:
            <t t-esc="empleado.funcion"/>
            </strong>

            </div>

            </div>

            </div>


            <t t-set="contador" t-value="contador + 1"/>

            </t>

            </t>


            <!-- ================= EMPAQUE ================= -->

            <t t-foreach="state.valores_empleados" t-as="empleado" t-key="'empaque_'+empleado.id">

            <t t-if="empleado.funcion &amp;&amp; empleado.funcion.toLowerCase().includes('empaque')">

            <t t-if="!grupo_empaque_mostrado">

            <div class="col-12">
            <h3 style="color:#01579b;">
            <strong>FUNCION: EMPAQUE</strong>
            </h3>
            <hr/>
            </div>

            <t t-set="grupo_empaque_mostrado" t-value="true"/>

            </t>


            <div class="col-md-4 col-sm-6 mb-4 d-flex align-items-stretch">

            <div class="border border-2 card shadow borderless w-100"
            style="border:0px; background-color:#25333e !important; color:white">

            <t t-esc="contador"/>


            <div class="card-body rounded"
