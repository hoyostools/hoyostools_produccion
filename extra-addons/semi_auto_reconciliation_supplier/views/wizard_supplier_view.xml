<odoo>

    <record id="view_supplier_reconciliation_wizard" model="ir.ui.view">
        <field name="name">semi.auto.reconciliation.supplier.wizard.form</field>
        <field name="model">semi.auto.reconciliation.supplier.wizard</field>
        <field name="arch" type="xml">
            <form string="Cruce Proveedores">
                <group>
                    <field name="date_due_from"/>
                    <field name="date_due_to"/>
                </group>

                <footer>
                    <button name="confirm"
                            string="Buscar Documentos"
                            type="object"
                            class="btn-primary"/>

                    <button string="Cancelar"
                            special="cancel"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_open_select_suppliers_wizard" model="ir.actions.act_window">
        <field name="name">Cruce Proveedores</field>
        <field name="res_model">semi.auto.reconciliation.supplier.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_semi_auto_reconciliation_supplier_lines"
              name="Cruce Proveedores"
              parent="account.menu_finance_payables"
              action="action_open_select_suppliers_wizard"/>

</odoo>