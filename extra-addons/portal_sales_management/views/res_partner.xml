<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_partner_view_form" model="ir.ui.view">
        <field name="name">res.partner.view.form.inherit.portal</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='sales_purchases']//field[@name='user_id']" position="replace">
                <field name="user_id" widget="many2one_avatar_user" domain="['|', ('share', '=', False), ('partner_id.is_seller', '=', True)]"/>
            </xpath>
            <xpath expr="//field[@name='category_id']" position="after">
                <field name="is_seller"/>
            </xpath>
        </field>
    </record>
</odoo>
