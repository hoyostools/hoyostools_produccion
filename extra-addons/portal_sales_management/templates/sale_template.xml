<odoo>


    <template id="portal_my_orders_inherit" name="My Sales Orders Template"
              inherit_id="sale.portal_my_orders" priority="35">

        <xpath expr="//t[@t-if='orders']" position="before">
            <div class="btn-group flex-grow-1 mb-1">
                <a class="btn btn-secondary o_print_btn" href="/my/quotes/create" title="Create"
                   target="_blank">
                    <i class="fa fa-plus"/>
                    Create
                </a>
            </div>
        </xpath>
    </template>


    <template id="portal_my_quotations_inherit" name="My Quotations"
              inherit_id="sale.portal_my_quotations" priority="35">

        <xpath expr="//t[@t-if='quotations']" position="before">
            <div class="btn-group flex-grow-1 mb-1">
                <a class="btn btn-secondary o_print_btn" href="/my/quotes/create" title="Create"
                   target="_blank">
                    <i class="fa fa-plus"/>
                    Create
                </a>
            </div>
        </xpath>
    </template>


    <template id="sale_order_portal_template" name="Sales Order Portal Template"
              inherit_id="sale.sale_order_portal_template" priority="35">


        <xpath expr="//t[@t-set='o_portal_fullwidth_alert']" position="inside">
            <p class="alert alert-danger mt8" t-if="request.params.get('error_msg')" role="alert">
                <t t-esc="request.params.get('error_msg')"/>
            </p>
        </xpath>
        <xpath expr="//t[@t-set='entries']" position="replace">
            <t t-set="entries">
                <div class="d-flex flex-column gap-4">
                    <div class="d-flex flex-column gap-2" id="sale_order_sidebar_button">
                        <a t-if="sale_order._has_to_be_signed()" role="button" class="btn btn-primary d-block"
                           data-bs-toggle="modal" data-bs-target="#modalaccept" href="#">
                            <i class="fa fa-check"/>
                            <t t-if="sale_order._has_to_be_paid()">Sign &amp; Pay</t>
                            <t t-else="">Accept &amp; Sign</t>
                        </a>
                        <a t-elif="sale_order._has_to_be_paid()" role="button" id="o_sale_portal_paynow"
                           data-bs-toggle="modal" data-bs-target="#modalaccept" href="#"
                           t-att-class="'d-block %s' % ('btn btn-light' if sale_order.transaction_ids else 'btn btn-primary')">
                            <i class="fa fa-check"/>
                            <t t-if="not sale_order.signature">Accept &amp; Pay</t>
                            <t t-else="">Pay Now</t>
                        </a>
                        <div class="o_download_pdf d-flex gap-1 flex-lg-column flex-xl-row">
                            <div class="flex-grow-1">
                                <a class="btn btn-secondary o_print_btn o_portal_invoice_print d-block"
                                   t-att-href="sale_order.get_portal_url(report_type='pdf')" id="print_invoice_report"
                                   title="View Details" target="_blank">
                                    <i class="fa fa-print"/>
                                    View Details
                                </a>
                            </div>

                            <div class="btn-group flex-grow-1 mb-1">
                                <a class="btn btn-secondary o_print_btn" href="/my/quotes/create" title="Create"
                                   target="_blank">
                                    <i class="fa fa-plus"/>
                                    Create
                                </a>
                            </div>
                        </div>
                    </div>

                    <div class="navspy flex-grow-1 ps-0" t-ignore="true" role="complementary">
                        <ul class="nav flex-column bs-sidenav"></ul>
                    </div>

                    <t t-if="not sale_order.is_expired and sale_order.state in ['draft', 'sent']">
                        <div t-if="sale_order.validity_date">
                            <small>
                                <b>This offer expires on</b>
                            </small>
                            <div t-field="sale_order.validity_date"></div>
                        </div>
                        <div t-if="sale_order.amount_undiscounted - sale_order.amount_untaxed &gt; 0.01"
                             class="list-group-item flex-grow-1">
                            <small>
                                <b class="text-muted">Your advantage</b>
                            </small>
                            <small>
                                <b t-field="sale_order.amount_undiscounted"
                                   t-options='{"widget": "monetary", "display_currency": sale_order.currency_id}'
                                   style="text-decoration: line-through"
                                   class="d-block mt-1"
                                   data-id="amount_undiscounted"/>
                            </small>
                            <t t-if="sale_order.amount_untaxed == sale_order.amount_total">
                                <h4 t-field="sale_order.amount_total" class="text-success" data-id="total_amount"/>
                            </t>
                            <t t-else="">
                                <h4 t-field="sale_order.amount_untaxed" class="text-success mb-0"
                                    data-id="total_untaxed"/>
                                <small>(
                                    <span t-field="sale_order.amount_total" data-id="total_amount"/>
                                    Incl. tax)
                                </small>
                            </t>
                        </div>
                    </t>

                    <div t-if="sale_order.user_id">
                        <h6>
                            <small class="text-muted">Your contact</small>
                        </h6>
                        <div class="o_portal_contact_details d-flex flex-column gap-2">
                            <div class="d-flex justify-content-start align-items-center gap-2">
                                <img class="o_avatar o_portal_contact_img rounded"
                                     t-att-src="image_data_uri(sale_order.user_id.avatar_1024)" alt="Contact"/>
                                <div>
                                    <h6 class="mb-0" t-out="sale_order.user_id.name"/>
                                    <a href="#discussion" class="d-flex align-items-center gap-2 small fw-bold">
                                        Send message
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </t>
        </xpath>
    </template>


    <template id="portal_my_quotes_create" name="Create Quotation">
        <t t-call="portal.portal_layout">
            <p class="alert alert-danger mt8" t-if="request.params.get('error_msg')" role="alert">
                <t t-esc="request.params.get('error_msg')"/>
            </p>
            <form data-model_name="sale.order" method="post"
                  class="s_website_form form-horizontal container-fluid" enctype="multipart/form-data">
                <t t-call="portal.portal_record_layout">
                    <t t-set="card_header">
                        <div class="row no-gutters">
                            <div class="col-md">
                                <h5 class="mb-1 mb-md-0">
                                    Create new quote
                                </h5>
                            </div>
                            <div class="col-md text-md-right">
                                <button id="create_quotation_data" class="btn btn-primary">Save</button>

                                <a t-attf-href="/my/quotes">
                                    <button class="btn btn-danger btn-md" type="button" special="cancel">Cancel</button>
                                </a>
                            </div>
                        </div>
                    </t>
                    <t t-set="card_body">
                        <div class="row no-gutters">
                            <div class="col-md-12 col-sm-12">
                                <div class="form-group row">

                                    <div class="col-6">
                                        <div class="row">
                                            <div class="col-4">
                                                <label for="partner_ids" class="control-label">Customer</label>
                                            </div>
                                            <div class="col-8">
                                                <select id="partner_id" name="partner_id"
                                                        t-attf-class="form-control col-md-4 col-sm-4">
                                                    <t t-foreach="partner_ids or []" t-as="partner_id">
                                                        <option t-att-partner_id="partner_id['name']"
                                                                t-att-value="partner_id['id']"
                                                                t-att-selected="partner_id['id']">
                                                            <t t-esc="partner_id['name']"/>
                                                        </option>
                                                    </t>
                                                </select>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-6">
                                        <div class="row">
                                            <div class="col-4">
                                                <label for="date_order" class="control-label">Order Date</label>
                                            </div>
                                            <div class="col-8">
                                                <input type="date" name="date_order" id="date_order"
                                                       t-att-value="datetime.datetime.now()"
                                                       class="form-control col-md-3 col-sm-3 datetimepicker-input"
                                                       required="required"/>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-6">
                                        <div class="row">
                                            <div class="col-4">
                                                <label for="pricelist_ids" class="control-label">Pricelist</label>
                                            </div>
                                            <div class="col-8">
                                                <select id="pricelist_id" name="pricelist_id"
                                                        t-attf-class="form-control col-md-4 col-sm-4">
                                                    <t t-foreach="pricelist_ids or []" t-as="pricelist_id">
                                                        <option t-att-pricelist_id="pricelist_id['name']"
                                                                t-att-value="pricelist_id['id']"
                                                                t-att-selected="pricelist_id['id']">
                                                            <t t-esc="pricelist_id['name']"/>
                                                        </option>
                                                    </t>
                                                </select>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <br/>
                                <div class="article">
                                    <table class="table table-bordered rfq_table">
                                        <thead>
                                            <tr>
                                                <th>Product</th>
                                                <th>Description</th>
                                                <th>Unit Price</th>
                                                <th>Qty</th>
                                                <th>Total</th>
                                                <th></th>
                                            </tr>
                                        </thead>
                                        <tbody class="rfq_table_body" id="rfq_table">
<!--                                            <t t-call="portal_sales_management.add_new_line"/>-->
                                        </tbody>

                                    </table>
                                    <div>
                                        <a id="r_add_new_line" href="#" role="button">Agregar nueva linea
                                            <span title="save" aria-label="Save   "/>
                                        </a>
                                    </div>
                                </div>
                                <br/>
                                <br/>

                                <!--                                <div class="form-group row">-->
                                <!--                                    <label class="o_label col-md-2 col-sm-2" for="ufile">Add Attachments</label>-->
                                <!--                                    <input type="file" id="uploadImage"-->
                                <!--                                           class="form-control col-md-9 col-sm-9 o_forum_file_upload" name="ufile"-->
                                <!--                                           accept="image/*,application/pdf" multiple="multiple"/>-->
                                <!--                                </div>-->
                            </div>
                        </div>
                    </t>
                </t>
            </form>

        </t>
    </template>


    <template id="add_new_line">
        <tr class="rfq_row" id="tr">
            <td id="product_id_td">
                <select id="product_id" name="product_id"
                        t-attf-class="form-control col-md-4 col-sm-4 select2">
                    <option value="" selected="1">Seleccionar producto</option>
                    <t t-foreach="product_ids or []" t-as="product_id">
                        <option t-att-product_id="product_id['name']"
                                t-att-value="product_id['id']"
                                >
                            <t t-esc="product_id['name']"/>
                        </option>
                    </t>
                </select>
            </td>
            <td id="product_description_td">
                <input id="product_description" name="product_description"
                       type="text"
                       string="Description"
                       class="form-control col-md-12 col-sm-9"/>
            </td>
            <td id="unit_price_td">
                <input id="price_unit" name="price_unit" type="text"
                       string="Unit Price" class="form-control col-md-12 col-sm-9"/>
            </td>
            <td id="product_qty_td">
                <input id="product_qty" name="product_qty" type="text" value="1"
                       string="Quantity" class="form-control col-md-12 col-sm-9"
                       required="required"/>
            </td>

            <td id="price_subtotal_td">
                <input id="price_subtotal" name="price_subtotal" type="text" readonly="1"
                       string="Sub Total" class="form-control col-md-12 col-sm-9"/>
            </td>
            <td id="pr_row_delete_td">
                <a t-attf-href="#" id="pr_row_delete">
                    <span class="fa fa-trash-o remove-optionnal-item" title="Delete"
                          aria-label="Delete"/>
                </a>
            </td>

        </tr>
    </template>
</odoo>
