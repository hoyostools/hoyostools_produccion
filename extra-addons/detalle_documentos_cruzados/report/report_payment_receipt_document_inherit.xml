<odoo>
    <template id="report_payment_detalle_documentos_cruzados" inherit_id="account.report_payment_receipt_document">
        <xpath expr="//t/div" position="replace">
                <div class="page">
                    <h3>
                        <strong>Recibo de pago:
                            <span t-field="o.name"/>
                        </strong>
                    </h3>
                    <div class="mb-4 mt-3">
                        <div class="row">
                            <div class="col-6" t-if="o.date">
                                Fecha de Pago:
                                <span t-field="o.date"/>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-6" t-if="o.partner_type">
                                <t t-if="o.partner_type == 'customer'">
                                    Tercero:
                                </t>
                                <t t-if="o.partner_type == 'supplier'">
                                    Proveedor:
                                </t>
                                <span t-field="o.partner_id"/>
                            </div>
                            <div class="col-6" t-if="o.payment_method_id">
                                Método de pago:
                                <span t-field="o.payment_method_id.name"/>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-6" t-if="o.amount">
                                Importe de Pago:
                                <span t-field="o.amount"
                                      t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                            </div>
                            <div class="col-6" t-if="o.ref">
                                Memo:
                                <span t-field="o.ref"/>
                            </div>
                        </div>
                    </div>
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>
                                    <span>Fecha factura</span>
                                </th>
                                <th>
                                    <span>Número de factura</span>
                                </th>
                                <th>
                                    <span>Importe</span>
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-set="invoices" t-value="o.take_payment_receipt_data()"/>
                            <t t-foreach="invoices[0]" t-as="row">
                                <tr>
                                    <td>
                                        <span t-esc="row[0]"/>
                                    </td>
                                    <td>
                                        <span t-esc="row[1]"/>
                                    </td>
                                    <td>
                                        <span t-esc="row[2]"/>
                                    </td>
                                </tr>
                            </t>
                            <t t-foreach="invoices[1]" t-as="residual">
                                    <td/>
                                    <td class="text-right">
                                        <strong>Importe debido para
                                            <t t-esc="residual[0]"/>
                                        </strong>
                                    </td>
                                    <td class="text-right">
                                        <strong>
                                            <t t-esc="residual[1]"/>
                                        </strong>
                                    </td>
                                </t>
                            <tr>
                            </tr>
                        </tbody>
                    </table>
                    <t t-if="o.line_ids">
                        <br/>
                        <h6>
                            <span>Apuntes Contables
                                <br/>
                            </span>
                        </h6>
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th>
                                        <span>Asiento contable</span>
                                    </th>
                                    <th>
                                        <span>Cuenta</span>
                                    </th>
                                    <th>
                                        <span>Descripción</span>
                                    </th>
                                    <th class="text-right">
                                        <span>Debe</span>
                                    </th>
                                    <th class="text-right">
                                        <span>Haber</span>
                                    </th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="o.line_ids" t-as="move">
                                    <td>
                                        <span t-field="move.move_id.display_name"/>
                                    </td>
                                    <td>
                                        <span t-field="move.account_id"/>
                                    </td>
                                    <td>
                                        <span t-field="move.name"/>
                                    </td>
                                    <td class="text-right">
                                        <span t-field="move.debit"/>
                                    </td>
                                    <td class="text-right">
                                        <span t-field="move.credit"/>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </t>
                </div>
        </xpath>
    </template>
</odoo>