<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_credit_risk_type_tree" model="ir.ui.view">
        <field name="name">credit.risk.type.tree</field>
        <field name="model">credit.risk.type</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="days_overdue"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="view_credit_risk_type_form" model="ir.ui.view">
        <field name="name">credit.risk.type.form</field>
        <field name="model">credit.risk.type</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="days_overdue"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_credit_risk_type" model="ir.actions.act_window">
        <field name="name">Tipos de Riesgos</field>
        <field name="res_model">credit.risk.type</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- Ajusta el parent según tu menú de contactos -->
    <menuitem
        id="menu_credit_risk_type"
        name="Tipos de Riesgos"
        parent="contacts.res_partner_menu_config"
        action="action_credit_risk_type"
        sequence="50"/>
</odoo>