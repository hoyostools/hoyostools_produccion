<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record model="ir.ui.view" id="view_invoice_form">
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form" />
        <field name="arch" type="xml">

            <xpath expr="//button[@name='button_draft']" position="before">
                <button name="compute_electronic_invoice"
                    type="object" groups="l10n_co_e_invoicing.report_dian_users"
                    string="Enviar a la DIAN"
                    invisible="state != 'posted' or status_dian_document == '00'"
                    />
            </xpath>

            <xpath expr="//field[@name='invoice_date']" position="after">
                <field name="approve_token" invisible="1"/>
                <field name="invoice_rating" readonly="1"/>
                <field name="refuse_text" invisible="invoice_rating != 'refuse'" readonly="1"/>
                <field name="move_type"/>
                <field name="send_invoice_to_dian" invisible="1"/><field name="cufe_cude" invisible="move_type not in ('in_invoice', 'in_refund')"/>
                <field name="operation_type"
                    invisible="move_type not in ('out_invoice', 'out_refund')"
                    readonly="state != 'draft'"
                    required="move_type == 'out_invoice'"
                    />
                <field name="invoice_type_code"
                    invisible="move_type not in ('out_invoice', 'out_refund')"
                    readonly="state != 'draft'"
                    required="move_type == 'out_invoice'"
                    />
                <field name="is_invoice_out_odoo"
                    invisible="move_type not in ('out_invoice', 'out_refund')"
                    readonly="state != 'draft'"
                    required="move_type == 'out_invoice'"
                    />
                <field name="period_start_date"
                    invisible="move_type not in ('out_invoice', 'out_refund') or operation_type != '22'"
                    required="move_type in ('out_invoice', 'out_refund') and operation_type == '22'"
                    readonly="state != 'draft'"/>
                <field name="period_end_date"
                    invisible="move_type not in ('out_invoice', 'out_refund') or operation_type != '22'"
                    required="move_type in ('out_invoice', 'out_refund') and operation_type == '22'"
                    readonly="state != 'draft'"/>
                <field name="id_invoice_refound"
                    invisible="move_type not in ('out_invoice', 'out_refund')  or not is_invoice_out_odoo"
                    readonly="state != 'draft'"
                    />
                <field name="uuid_invoice"
                    invisible="move_type not in ('out_invoice', 'out_refund')  or not is_invoice_out_odoo"
                    readonly="state != 'draft'"
                    />
                <field name="issue_date_invoice"
                    invisible="move_type not in ('out_invoice', 'out_refund')  or not is_invoice_out_odoo"
                    readonly="state != 'draft'"
                    />
                <field name="customizationid_invoice"
                    invisible="move_type not in ('out_invoice', 'out_refund')  or not is_invoice_out_odoo"
                    required="move_type == 'out_invoice'"
                    readonly="state != 'draft'"
                    />
            </xpath>

            <xpath expr="//notebook" position="inside">
                <page name="einvoicing" string="E-Invoicing" invisible="move_type not in ('out_invoice', 'out_refund', 'in_invoice', 'in_refund')">
                    <field name="dian_document_lines" mode="tree">
                        <tree string="DIAN Documents" create="0" edit="0">
                            <field name="cufe_cude"/>
                            <field name="create_date"/>
                            <field name="xml_filename"/>
                            <field name="get_status_zip_status_code"/>
                            <field name="state"/>
                        </tree>
                    </field>
                    <field name="status_dian_document"/>
                </page>
            </xpath>

            <xpath expr="//field[@name='invoice_incoterm_id']" position="attributes">
                <attribute name="required">invoice_type_code == '02'</attribute>
            </xpath>

            <xpath expr="//field[@name='ref']" position="after">
                <field name="aiu" required="operation_type == '09'" invisible="move_type not in ('out_invoice', 'out_refund'), operation_type != '09'"/>
                <field name="mandante_id" invisible="move_type not in ('out_invoice', 'out_refund'), operation_type != '11', customizationid_invoice != '11'" required="operation_type == '11', customizationid_invoice == '11'"
                />
                <field name="orden_compra"></field>
                <field name="order_reference"></field>
            </xpath>

            <div class="oe_button_box" position="inside">
                <button type="object" class="oe_stat_button" name="action_view_credit_notes" icon="fa-plus" invisible="credit_note_count == 0">
                    <div class="o_field_widget o_stat_info">
                        <span class="o_stat_value"><field name="credit_note_count"/></span>
                        <span class="o_stat_text">Notas Crédito</span>
                    </div>
                </button>
            </div>

            <xpath expr="//sheet" position="before">
                <field name="warn_pfx" invisible="1"/>
                <field name="pfx_available_days" invisible="1"/>
                 <!-- background-color:#ff9e9e; -->
                <div class="alert alert-danger" role="alert" style="margin-bottom:0px;" invisible="not warn_pfx">
                    <span style="font-weight:bold;font-size:18px;">¡Advertencia! </span>
                    El certificado .pfx para Facturación Electrónica esta por vencerse.
                    <p style="font-weight:bold;padding-left:110px">Dias restantes: <field name="pfx_available_days"/>.<br/>
                    Por favor, contacte con su administrador para adelantar su actualización.</p>
                </div>
                <field name="status_dian_document" invisible="1"/>
                <div class="alert alert-danger" role="alert" style="margin-bottom:0px;" invisible ='status_dian_document == "00" or status_dian_document == False'>
                    <span style="font-weight:bold;font-size:18px;">¡Advertencia! </span>
                    La Factura Electrónica aún no está autorizada por la DIAN. <strong>Por favor, revisar el documento DIAN para consultar su estado nuevamente o validar el motivo de rechazo.</strong><br/>
                    <span style="font-weight:bold;padding-left:110px"> Estado Factura Electrónica: </span><field name="status_dian_document"/>
                </div>
                <div class="alert alert-success" role="alert" style="margin-bottom:0px;" invisible ='status_dian_document != "00" or status_dian_document == False'>
                    <span style="font-weight:bold;">Estado Factura Electrónica: </span><field name="status_dian_document"/>
                </div>
            </xpath>
        </field>
    </record>

    <record id="email_template_for_einvoice" model="mail.template">
        <field name="name">Electronic Invoice - Send by Email</field>
        <field name="model_id" ref="account.model_account_move"/>
        <field name="email_from">{{object.company_id.einvoicing_email}}</field>
        <field name="reply_to">{{object.company_id.einvoicing_email}}</field>
        <field name="subject">{{object.company_id.partner_id.identification_document}} ; {{object.company_id.name}} ; {{object.name}} ; 01 ; {{object.company_id.name}}</field>
        <field name="email_to">{{(object.partner_id.email) or (object.company_id.einvoicing_partner_no_email)}}</field>
        <field name="auto_delete" eval="False"/>
        <field name="lang">{{object.partner_id.lang}}</field>
        <field name="body_html" type="html">
            <div style="font-family: 'Lucica Grande', Ubuntu, Arial, Verdana, sans-serif; font-size: 12px; color: #222222; background-color: #FFF; ">
                <p style="margin:0px 0 12px 0;box-sizing:border-box;">Señor(es),</p>
                <p style="margin:0px 0 12px 0;box-sizing:border-box;"> <t t-out="object.partner_id.name or ''" data-oe-t-inline="true" contenteditable="false" oe-keep-contenteditable=""/></p><br/><br/>
            <p style="margin:0px 0 12px 0;box-sizing:border-box;">Le informamos que ha recibido una factura/nota electrónica de  <t t-out="object.company_id.name or ''" data-oe-t-inline="true" contenteditable="false" oe-keep-contenteditable="">:</t></p><br/><br/>
            <p style="margin:0px 0 12px 0;box-sizing:border-box;">Número de factura: <strong style="box-sizing:border-box;font-weight:500;">  <t t-out="object.name or ''" data-oe-t-inline="true" contenteditable="false" oe-keep-contenteditable=""> </t></strong></p>
            <p style="margin:0px 0 12px 0;box-sizing:border-box;">Token de factura: <strong style="box-sizing:border-box;font-weight:500;">  <t t-out="object.approve_token or ''" data-oe-t-inline="true" contenteditable="false" oe-keep-contenteditable=""> </t></strong></p>
            <p style="margin:0px 0 12px 0;box-sizing:border-box;">A nombre de: <strong style="box-sizing:border-box;font-weight:500;">  <t t-out="object.partner_id.name or ''" data-oe-t-inline="true" contenteditable="false" oe-keep-contenteditable=""> </t></strong></p>
            <p style="margin:0px 0 12px 0;box-sizing:border-box;">Valor Total: <strong style="box-sizing:border-box;font-weight:500;">  <t t-out="object.amount_total or ''" data-oe-t-inline="true" contenteditable="false" oe-keep-contenteditable=""/> <t t-out="object.currency_id.name or ''" data-oe-t-inline="true" contenteditable="false" oe-keep-contenteditable=""/> </strong></p><br/><br/>
            <p style="margin:0px 0 12px 0;box-sizing:border-box;">Si tiene inquietud respecto a la información contenida en la factura/nota electrónica, responda este correo electrónico.</p><br/>


            <p style="margin:0px 0 12px 0;box-sizing:border-box;">Si pasados tres (3) días hábiles siguientes a la recepción de la factura/nota electrónica, no se ha recibido un correo indicando rechazo de la factura/nota electrónica, el sistema la dará por aceptada.</p><br/>
            <p style="margin:0px 0 12px 0;box-sizing:border-box;">Escriba a <t t-out="object.company_id.einvoicing_email or ''" data-oe-t-inline="true" contenteditable="false" oe-keep-contenteditable=""/> si desea modificar sus datos para el envío de la factura/nota electrónica.</p><br/>

            <p style="margin:0px 0 12px 0;box-sizing:border-box;">Cordialmente,</p><br/>
            <p style="margin:0px 0 12px 0;box-sizing:border-box;"><strong style="box-sizing:border-box;font-weight:500;"><t t-out="object.company_id.name or ''" data-oe-t-inline="true" contenteditable="false" oe-keep-contenteditable=""/></strong></p>
            <table summary="o_mail_notification" style="width:100%;border-top:1px solid #e1e1e1;">
                <table style="width:100%;text-align:center;">
                    <tbody>
                        <tr>
                            <td>
                                <a role="button" class="dropdown-toggle o-no-caret btn" t-attf-href="{{ object.get_base_url() }}/mail/view?model=account.move&amp;res_id={{ object.id }}&amp;approve_token={{ object.approve_token }}" style="background-color:#685563;color:#fff;border-radius:10px;font-size:15px">
                                Ver <t t-out="object.name"/></a>
                            </td>

                            <td>
                                <a role="button" class="dropdown-toggle o-no-caret btn" t-attf-href="{{ object.get_base_url() }}/approve-electronic-invoice/{{ object.approve_token }}/True" style="background-color:#35979C;color:#fff;border-radius:10px;font-size:15px">
                                Aprobar</a>
                            </td>
                            <td>
                                <a role="button" class="dropdown-toggle o-no-caret btn" t-attf-href="{{ object.get_base_url() }}/approve-electronic-invoice/{{ object.approve_token }}/False" style="background-color:#B9210F;color:#fff;border-radius:10px;font-size:15px">
                                Rechazar</a>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </table>
        </div>
        </field>
    </record>
</odoo>
