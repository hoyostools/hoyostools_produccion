<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
         <record id="view_res_bank_form" model="ir.ui.view">
            <field name="name">view.res.bank.form</field>
            <field name="model">res.bank</field>
            <field name="inherit_id" ref="base.view_res_bank_form" />
            <field name="arch" type="xml">
                <xpath expr="//field[@name='email']" position="after">
                    <field name="document_type_bank_id" force_save="1" invisible="0"/>
                    <field name="identification_document_bank" force_save="1" invisible="0"/>
                    <field name="check_digit_bank" invisible = "document_type_bank_id != '31'"/>
                </xpath>
            </field>
        </record>

    </data>
</odoo>