<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="pos_config_view_form_inherit_pos_auto_invoice" model="ir.ui.view">
            <field name="name">res.config.setting.form.inherit.auto.invoice</field>
            <field name="model">res.config.settings</field>
            <field name="inherit_id" ref="point_of_sale.res_config_settings_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//block[@id='pos_accounting_section']" position="inside">
                    <setting help="Default invoice button is selected in pos">
                        <field name="is_auto_invoice"/>
                    </setting>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
