<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- VISTA DEL ASISTENTE PARA ORDEN PARCIAL -->
    <record id="view_purchase_partial_order_wizard_form" model="ir.ui.view">
        <field name="name">purchase.partial.order.wizard.form</field>
        <field name="model">purchase.partial.order.wizard</field>
        <field name="arch" type="xml">
            <form string="Crear Orden Parcial">
                <group>
                    <field name="option"/>
                    <field name="existing_order_id" modifiers="{'invisible': [('option', '!=', 'existing')]}"/>
                </group>
                <footer>
                    <button name="confirm_action" type="object" string="Confirmar" class="oe_highlight"/>
                    <button string="Cancelar" class="oe_link" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- ACCIÓN PARA ABRIR EL ASISTENTE -->
    <record id="action_purchase_partial_order_wizard" model="ir.actions.act_window">
        <field name="name">Crear Orden Parcial</field>
        <field name="res_model">purchase.partial.order.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
