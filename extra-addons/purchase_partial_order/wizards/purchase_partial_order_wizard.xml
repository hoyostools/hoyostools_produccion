<odoo>
    <record id="view_purchase_partial_order_wizard_form" model="ir.ui.view">
        <field name="name">purchase.partial.order.wizard.form</field>
        <field name="model">purchase.partial.order.wizard</field>
        <field name="arch" type="xml">
            <form string="Crear Orden Parcial">
                <group>
                    <field name="option" widget="radio"/>
                    <field name="existing_order_id"
                           invisible="option != 'existing'" required="option == 'existing'"/>
                </group>
                <footer>
                    <button name="confirm_action" type="object" string="Confirmar" class="oe_highlight"/>
                    <button string="Cancelar" class="oe_link" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
