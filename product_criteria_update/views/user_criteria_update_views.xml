<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="user_criteria_update_view_tree" model="ir.ui.view">
        <field name="name">user.criteria.update.tree</field>
        <field name="model">user.criteria.update</field>
        <field name="arch" type="xml">
            <tree editable="bottom">
                <field name="user_id"/>
            </tree>
        </field>
    </record>

    <record id="action_user_criteria_update" model="ir.actions.act_window">
        <field name="name">Encargados reglas de reordenamiento</field>
        <field name="res_model">user.criteria.update</field>
        <field name="view_mode">tree</field>
    </record>

    <menuitem id="menu_user_criteria_update" name="Encargados reglas de reordenamiento"
              parent="stock.menu_product_in_config_stock" sequence="10"
              action="product_criteria_update.action_user_criteria_update"/>

</odoo>