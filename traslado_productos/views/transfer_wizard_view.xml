<odoo>
    <record id="view_transfer_wizard_form" model="ir.ui.view">
        <field name="name">transfer.wizard.form</field>
        <field name="model">stock.transfer.wizard</field>
        <field name="arch" type="xml">

            <form string="Trasladar Producto">

                <group>
                    <field name="picking_type_id"/>
                    <field name="transfer_mode"/>

                    <field name="destination_location_id"
                           invisible="transfer_mode != 'same'"
                           required="transfer_mode == 'same'"/>
                    <field name="state_option"/>
                    <field name="user_id"
                           invisible="state_option in ['done']"/>
                </group>

                <field name="line_ids">
                    <tree editable="bottom">
                        <field name="product_id" readonly="1" force_save="1"/>
                        <field name="location_id" readonly="1" force_save="1"/>
                        <field name="available_qty" readonly="1" force_save="1"/>
                        <field name="qty_to_move"/>
                        <field name="location_dest_id" invisible="parent.transfer_mode == 'same'"/>
                    </tree>
                </field>

                <footer>
                    <button name="action_create_transfer"
                            type="object"
                            string="Crear"
                            class="btn-primary"/>
                    <button string="Cancelar"
                            special="cancel"/>
                </footer>

            </form>

        </field>
    </record>
</odoo>
