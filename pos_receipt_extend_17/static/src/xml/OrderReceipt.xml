<?xml version="1.0" encoding="UTF-8"?>
<!--To add the customer details in the settings page-->
<templates id="template" xml:space="preserve">
    <t t-name="OrderReceipt" t-inherit="point_of_sale.ReceiptHeader"
    t-inherit-mode="extension" owl="1">

        <xpath expr="//div[hasclass('pos-receipt-contact')]" position="inside">

            <t t-if="this.env.services.pos.config.customer_details">

                <div t-if="this.env.services.pos.config.customer_name and this.props.data.customer_name"
                    style="font-weight:bold;font-size:11px;">
                    Nombre Cliente:
                    <t t-esc="this.props.data.customer_name"/>
                </div>

                <div t-if="this.env.services.pos.config.customer_address and this.props.data.customer_address"
                    style="font-weight:bold;font-size:11px;">
                    Dirección:
                    <t t-esc="this.props.data.customer_address"/>
                </div>

                <div t-if="this.env.services.pos.config.customer_mobile and this.props.data.customer_mobile"
                    style="font-weight:bold;font-size:11px;">
                    Móvil:
                    <t t-esc="this.props.data.customer_mobile"/>
                </div>

                <div t-if="this.env.services.pos.config.customer_phone and this.props.data.customer_phone"
                    style="font-weight:bold;font-size:11px;">
                    Teléfono:
                    <t t-esc="this.props.data.customer_phone"/>
                </div>

                <div t-if="this.env.services.pos.config.customer_email and this.props.data.customer_email"
                    style="font-weight:bold;font-size:11px;">
                    Email:
                    <t t-esc="this.props.data.customer_email"/>
                </div>

                <div t-if="this.env.services.pos.config.customer_vat and this.props.data.customer_vat"
                    style="font-weight:bold;font-size:11px;">
                    Identificación:
                    <t t-esc="this.props.data.customer_vat"/>
                </div>

            </t>

        </xpath>

    </t>
    <t t-name="OrderReceipt" t-inherit="point_of_sale.OrderReceipt"
       t-inherit-mode="extension" owl="1">
        <xpath expr="//img[@id='posqrcode']" position="replace">
            <div style="text-align: center;">
                <t t-if="props.data.headerData.img_cufe">
                    <img t-att-src="'data:image/png;base64,' + props.data.headerData.img_cufe"
                         style="width:110px; height:110px;" />
                </t>
                <t t-elif="!props.data.headerData.img_cufe || props.data.headerData.img_cufe == ''">
                    <img id="posqrcode"
                         t-att-src="props.data.pos_qr_code"
                         class="pos-receipt-logo" />
                </t>
                <div style="font-weight: bold; word-break: break-word; white-space: normal;">
                    <t t-if="props.data.headerData.cufe_cude">
                        CUFE/CUDE: <t t-esc="props.data.headerData.cufe_cude"/>
                    </t>
                </div>
            </div>
        </xpath>
    </t>
    <t t-name="custom.Orderline"
       t-inherit="point_of_sale.Orderline"
       t-inherit-mode="extension"
       owl="1">

        <xpath expr="//div[hasclass('product-name')]" position="replace">

            <div class="product-name d-inline-block flex-grow-1 fw-bolder pe-1 text-truncate">

                <t t-if="line.default_code">
                    [<t t-esc="line.default_code"/>]
                </t>

                <span class="text-wrap" t-esc="line.productName"/>

                <t t-slot="product-name"/>

            </div>
    
        </xpath>

    </t>
</templates>
