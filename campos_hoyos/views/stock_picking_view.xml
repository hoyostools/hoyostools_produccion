<odoo>
    <data>
        <record id="stock_picking_kanban_inherit_hoyos" model="ir.ui.view">
            <field name="name">stock.barcode.picking.kanban.inherit.hoyos</field>
            <field name="model">stock.picking</field>
            <field name="inherit_id" ref="stock.stock_picking_kanban"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='picking_type_id']" position="after">
                    <field name="address_complete"/>
                    <field name="carrier_id_name"/>
                </xpath>
                <xpath expr="//div[hasclass('o_kanban_record_bottom')]" position="after">
                    <field name="address_complete"/>
                </xpath>
                <xpath expr="//div[hasclass('o_kanban_record_top')]" position="after">
                    <field name="carrier_id_name"/>
                </xpath>
            </field>
        </record>

        <record id="stock_picking_form_inherit_hoyos" model="ir.ui.view">
            <field name="name">stock.picking.form.inherit.hoyos</field>
            <field name="model">stock.picking</field>
            <field name="inherit_id" ref="stock.view_picking_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='picking_type_id']" position="after">
                    <field name="packaging_order_observation"/>
                </xpath>
            </field>
        </record>

        <record id="stock_vpicktree_inherit_warehouse_id" model="ir.ui.view">
            <field name="name">stock.vpicktree.inherit.warehouse.id</field>
            <field name="model">stock.picking</field>
            <field name="inherit_id" ref="stock.vpicktree"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='location_dest_id']" position="after">
                    <field name="warehouse_id" optional="hide"/>
                </xpath>
            </field>
        </record>

    </data>
</odoo>