<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record model="ir.ui.view" id="sale_order_form_view_readonly_field_pos_categ_ids">
            <field name="name">sale.order.readonly.fields.form.pci</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_order_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='payment_term_id']" position="after">
                    <field name="is_user_gerencial" invisible="1"/>
                </xpath>
                <xpath expr="//field[@name='payment_term_id']" position="attributes">
                    <attribute name="readonly">state == 'sale' and not is_user_gerencial</attribute>
                </xpath>
                <xpath expr="//field[@name='user_id']" position="attributes">
                    <attribute name="readonly">state=='sale' and not is_user_gerencial</attribute>
                </xpath>
                <xpath expr="//field[@name='team_id']" position="attributes">
                    <attribute name="readonly">state=='sale' and not is_user_gerencial</attribute>
                </xpath>
                <xpath expr="//field[@name='client_order_ref']" position="attributes">
                    <attribute name="readonly">state=='sale' and not is_user_gerencial</attribute>
                </xpath>
                <xpath expr="//field[@name='tag_ids']" position="attributes">
                    <attribute name="readonly">state=='sale' and not is_user_gerencial</attribute>
                </xpath>
                <xpath expr="//field[@name='fiscal_position_id']" position="attributes">
                    <attribute name="readonly">state=='sale' and not is_user_gerencial</attribute>
                </xpath>
                <xpath expr="//field[@name='commitment_date']" position="attributes">
                    <attribute name="readonly">
                        (state in ['sale','cancel'] or locked==1) and (not is_user_gerencial)
                    </attribute>
                </xpath>
                <xpath expr="//field[@name='origin']" position="attributes">
                    <attribute name="readonly">state=='sale' and not is_user_gerencial</attribute>
                </xpath>
                <xpath expr="//field[@name='campaign_id']" position="attributes">
                    <attribute name="readonly">state=='sale' and not is_user_gerencial</attribute>
                </xpath>
                <xpath expr="//field[@name='medium_id']" position="attributes">
                    <attribute name="readonly">state=='sale' and not is_user_gerencial</attribute>
                </xpath>
                <xpath expr="//field[@name='source_id']" position="attributes">
                    <attribute name="readonly">state=='sale' and not is_user_gerencial</attribute>
                </xpath>
            </field>
        </record>

        <record model="ir.ui.view" id="sale_order_form_view_readonly_field_notas_logisticas">
            <field name="name">sale.order.readonly.fields.form.nl</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="campos_hoyos.logistic_service_page"/>
            <field name="arch" type="xml">

                <xpath expr="//field[@name='idOrden']" position="attributes">
                    <attribute name="readonly">state=='sale' and not is_user_gerencial</attribute>
                </xpath>
                <xpath expr="//field[@name='idb4b']" position="attributes">
                    <attribute name="readonly">state=='sale' and not is_user_gerencial</attribute>
                </xpath>
                <xpath expr="//field[@name='servicio_logistico']" position="attributes">
                    <attribute name="readonly">state=='sale' and not is_user_gerencial</attribute>
                </xpath>
                <xpath expr="//field[@name='nombre_logistico']" position="attributes">
                    <attribute name="readonly">state=='sale' and not is_user_gerencial</attribute>
                </xpath>
                <xpath expr="//field[@name='identificacion_logistico']" position="attributes">
                    <attribute name="readonly">state=='sale' and not is_user_gerencial</attribute>
                </xpath>
                <xpath expr="//field[@name='tipo_id_logistico']" position="attributes">
                    <attribute name="readonly">state=='sale' and not is_user_gerencial</attribute>
                </xpath>
                <xpath expr="//field[@name='address_logistica']" position="attributes">
                    <attribute name="readonly">state=='sale' and not is_user_gerencial</attribute>
                </xpath>
                <xpath expr="//field[@name='city_logistica']" position="attributes">
                    <attribute name="readonly">state=='sale' and not is_user_gerencial</attribute>
                </xpath>
                <xpath expr="//field[@name='state_logistico']" position="attributes">
                    <attribute name="readonly">state=='sale' and not is_user_gerencial</attribute>
                </xpath>
                <xpath expr="//field[@name='phone_logistico']" position="attributes">
                    <attribute name="readonly">state=='sale' and not is_user_gerencial</attribute>
                </xpath>
                <xpath expr="//field[@name='guia_url']" position="attributes">
                    <attribute name="readonly">state=='sale' and not is_user_gerencial</attribute>
                </xpath>
            </field>
        </record>

        <record model="ir.ui.view" id="sale_order_form_view_readonly_incoterm">
            <field name="name">sale.order.readonly.fields.form.incoterm</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale_stock.view_order_form_inherit_sale_stock"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='incoterm']" position="attributes">
                    <attribute name="readonly">state=='sale' and not is_user_gerencial</attribute>
                </xpath>
                <xpath expr="//field[@name='incoterm_location']" position="attributes">
                    <attribute name="readonly">state=='sale' and not is_user_gerencial</attribute>
                </xpath>
            </field>
        </record>

        <record model="ir.ui.view" id="sale_order_form_view_readonly_opportunity">
            <field name="name">sale.order.readonly.fields.form.opportunity</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale_crm.sale_view_inherit123"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='opportunity_id']" position="attributes">
                    <attribute name="readonly">state=='sale' and not is_user_gerencial</attribute>
                </xpath>
            </field>
        </record>
    </data>
</odoo>