<?xml version="1.0" encoding="UTF-8" ?>
<odoo noupdate="1">
    <record model="ir.actions.server" id="ir_server_inventory_projection">
        <field name="name">Calcular proyección</field>
        <field name="type">ir.actions.server</field>
        <field name="model_id" ref="model_stock_warehouse_orderpoint"/>
        <field name="binding_model_id" ref="model_stock_warehouse_orderpoint"/>
        <field name="state">code</field>
        <field name="code">
            action = record._compute_inventory_projection()
        </field>
    </record>
    <record model="ir.actions.server" id="ir_server_proyeccion_inventario">
        <field name="name">Calcular proyección</field>
        <field name="type">ir.actions.server</field>
        <field name="model_id" ref="model_product_product"/>
        <field name="binding_model_id" ref="model_product_product"/>
        <field name="state">code</field>
        <field name="code">
            action = record.calcular_proyeccion_inventario()
        </field>
    </record>
    <record id="action_server_calcular_rentabilidad_product_template" model="ir.actions.server">
        <field name="name">Calcular rentabilidad</field>
        <field name="type">ir.actions.server</field>
        <field name="model_id" ref="product.model_product_template"/>
        <field name="binding_model_id" ref="product.model_product_template"/>
        <field name="state">code</field>
        <field name="code">
            for record in records:
                record._compute_extreme_rentability()
        </field>
    </record>
</odoo>