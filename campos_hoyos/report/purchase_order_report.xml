        <template id="report_purchaseorder_document">
            <t t-call="web.html_container">
                <t t-call="web.external_layout">
                    <div>
                        <p>
                            <h1 style="color: #f07605">
                                Pedido de compra #
                                <t t-esc="o.name"/>
                            </h1>
                        </p>
                        <br/>
                        <table class="table table-borderless" style="border: none;">
                            <tr class="text-start" style="color:white; border: none;">
                                <th scope="col" style="width: 25%; background:white; border:none">
                                    <h5>
                                        <strong>Representante de Compra:</strong>
                                    </h5>
                                </th>
                                <th scope="col" style="width: 25%; background:white; border:none">
                                    <h5>
                                        <strong>Su referencia de pedido:</strong>
                                    </h5>
                                </th>
                                <th scope="col" style="width: 25%; background:white; border:none">
                                    <h5>
                                        <strong>Fecha de la Orden:</strong>
                                    </h5>
                                </th>
                                <th scope="col" style="width: 25%; background:white; border:none">
                                    <h5>
                                        <strong>Incoterm</strong>
                                    </h5>
                                </th>
                            </tr>
                            <tr class="text-start" style="border: none;">
                                <td style="border:none">
                                    <t t-esc="o.user_id.name"/>
                                </td>
                                <td style="border:none">
                                    <t t-esc="o.partner_ref"/>
                                </td>
                                <td style="border:none">
                                    <p t-field="o.date_approve" class="m-0"/>
                                </td>
                                <td class="text-start" style="border:none">
                                    <span t-field="o.incoterm_id.code"/>
                                    <span t-field="o.incoterm_location"/>
                                </td>
                            </tr>
                        </table>
                        <table class="table table-borderless" style="border: none;">
                            <thead>
                                <tr class="text-start" style="color:white; border: none;">
                                    <th style="width: 25%; border: none; background:white">
                                        <h5>
                                            <strong>Plazos de Pago:</strong>
                                        </h5>
                                    </th>
                                    <th scope="col" style="width: 25%; border: none; background:white">
                                        <h5>
                                            <strong>Proveedor:</strong>
                                        </h5>
                                    </th>
                                    <th scope="col" style="width: 25%; border: none; background:white">
                                        <h5>
                                            <strong>Entregar en:</strong>
                                        </h5>
                                    </th>
                                    <th style="width: 25%; border: none; background:white"></th>
                                </tr>
                            </thead>
                            <tr class="text-start" style="border: none;">
                                <td style="border: none; background:white">
                                    <t t-esc="o.payment_term_id.name"/>
                                </td>
                                <td style="border: none; background:white">
                                    <t t-esc="o.partner_id.name"/>
                                </td>
                                <td style="border: none; background:white">
                                    <t t-esc="o.picking_type_id.warehouse_id.name"/>:
                                    <t t-esc="o.picking_type_id.code"/>
                                </td>
                                <td style="border: none; background:white"></td>
                            </tr>
                        </table>
                        <!--                        tabla de productos-->
                        <table class="table table-sm o_main_table table-borderless mt-4">
                            <thead style="display: table-row-group">
                                <tr>
                                    <th name="th_description">
                                        <strong>Código</strong>
                                        <br/>
                                        <strong>Referencia</strong>
                                        <br/>
                                        <strong>Proveedor</strong>
                                    </th>
                                    <th name="th_name">
                                        <strong>Nombre</strong>
                                    </th>
                                    <th name="th_barcode" class="text-center">
                                        <strong>Barcode</strong>
                                    </th>
                                    <th name="th_taxes">
                                        <strong>Impuestos</strong>
                                    </th>
                                    <th name="th_quantity" class="text-end">
                                        <strong>Ctdad</strong>
                                    </th>
                                    <th name="th_price_unit" class="text-end">
                                        <strong>Precio Unitario</strong>
                                    </th>
                                    <th class="text-right">
                                        <strong>Desc. (%)</strong>
                                    </th>
                                    <th name="th_amount" class="text-end">
                                        <strong>Importe</strong>
                                    </th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="o.order_line" t-as="line">
                                    <td class="text-center" name="th_description">
                                        <t t-esc="line.product_id.default_code"/>
                                    </td>
                                    <td name="th_name">
                                        <t t-esc="line.product_id.display_name"/>
                                    </td>
                                    <td name="th_barcode" class="text-center">
                                        <t t-esc="line.product_id.barcode"/>
                                    </td>
                                    <td name="th_taxes">
                                    </td>
                                    <td name="th_quantity" class="text-end">
                                        <t t-esc="line.product_qty"/>
                                    </td>
                                    <td name="th_price_unit" class="text-end">
                                        <t t-esc="line.currency_id.name"/>$
                                        <t t-esc="line.price_unit"/>
                                    </td>
                                    <td class="text-right">
                                        <t t-esc="line.discount"/>
                                    </td>
                                    <td name="th_amount" class="text-end">
                                        <t t-esc="line.currency_id.name"/>
                                        <t t-esc="line.price_total"/>
                                    </td>
                                </tr>
                            </tbody>
                        </table>

                        <div style="width: 30%; float: right; margin-left:auto;">
                            <!-- Tabla para USD -->
                            <t t-if="o.currency_id.name == 'USD'">
                                <table class="table table-sm o_main_table table-borderless mt-4">
                                    <thead style="display: table-row-group">
                                        <tr class="text-end">
                                            <th>
                                                <strong>Monto Libre de Impuestos</strong>
                                            </th>
                                            <th>
                                                <t t-esc="o.currency_id.name"/>
                                                $<t t-esc="o.amount_untaxed"/>
                                            </th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr class="text-end" style="background:white">
                                            <td>
                                                <p>
                                                    IVA
                                                    de
                                                    <t t-esc="o.currency_id.name"/>
                                                    $<t t-esc="o.amount_untaxed"/>
                                                </p>
                                            </td>
                                            <td>
                                                $<t t-esc="o.amount_tax"/>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                                <table class="table table-sm o_main_table table-borderless mt-4">
                                    <thead style="display: table-row-group">
                                        <tr class="text-end">
                                            <th>
                                                <strong>Total</strong>
                                            </th>
                                            <th>
                                                <p>
                                                    <t t-esc="o.currency_id.name"/>$
                                                    $<t t-esc="o.amount_total"/>
                                                </p>
                                            </th>
                                        </tr>
                                    </thead>
                                </table>
                            </t>
                            <!-- Tabla para COP -->
                            <t t-else="">
                                <table class="table table-sm o_main_table table-borderless mt-4">
                                    <thead style="display: table-row-group">
                                        <tr class="text-end">
                                            <th>
                                                <strong>Subtotal</strong>
                                            </th>
                                            <th>
                                                <p>
                                                    $<t t-esc="o.amount_untaxed"/>
                                                </p>
                                            </th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr class="text-end" style="background:white;">
                                            <td>
                                                <p>
                                                    AR REN
                                                    de
                                                    $<t t-esc="o.amount_untaxed"/>
                                                </p>
                                            </td>
                                            <td>
                                                <p>

                                                </p>
                                            </td>
                                        </tr>
                                        <tr class="text-end" style="background:white;">
                                            <td>
                                                <p>
                                                    IVA 19%
                                                    de
                                                    $<t t-esc="o.amount_untaxed"/>
                                                </p>
                                            </td>
                                            <td>
                                                <p>
                                                    $<t t-esc="o.amount_tax"/>
                                                </p>
                                            </td>
                                        </tr>
                                        <tr class="text-end" style="background:white;">
                                            <td>
                                                <p>
                                                    R ICA
                                                    de
                                                    $<t t-esc="o.amount_untaxed"/>
                                                </p>
                                            </td>
                                            <td>
                                                <p>

                                                </p>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                                <table class="table table-sm o_main_table table-borderless mt-4">
                                    <thead style="display: table-row-group">
                                        <tr class="text-end">
                                            <th>
                                                <strong>Total</strong>
                                            </th>
                                            <th>
                                                <p>
                                                    $
                                                    <t t-esc="o.amount_total"/>
                                                </p>
                                            </th>
                                        </tr>
                                    </thead>
                                </table>
                            </t>
                        </div>

                        <div style="clear: both;"/>

                        <span>
                            <p style="margin-bottom: 0px;">
                                <strong>Notas:</strong>
                            </p>
                            <p style="margin-bottom: 0px;">-Solo se reciben facturación  hasta el día 27 de cada mes.
                            </p>
                            <p style="margin-bottom: 0px;">-No Aceptamos facturas generadas con precio y /o descuentos
                                diferentes a los aquí pactados ,tener en cuenta que el descuento financiero se tomara en
                                el plazo de esta orden de compra .
                            </p>
                            <p style="margin-bottom: 0px;">
                            </p>
                            <p style="margin-bottom: 0px;">-Como política interna y comercial, el plazo otorgado por su
                                empresa hacia <strong>Distribuciones HOYOSTOOLS SAS</strong>  se tomara <strong>NO con
                                    la fecha de factura sino
                                    con la Fecha de Entrega Física de la mercancía
                                </strong> incluyendo los descuentos financieros.
                            </p>
                            <p style="margin-bottom: 0px;">
                            </p>
                            <p style="margin-bottom: 0px;">-Este Pedido se Cancelara con Flete</p>
                            <p style="margin-bottom: 0px;">Flete Incluye Descargue (El descargue se realizara por cuenta
                                de la transportadora y/o Proveedor por orden de Llegada)
                            </p>
                            <br/>
                            <p style="text-size:x-smaller">
                                Este Pedido se recibirá en el siguiente Horario LUNES - VIERNES de 8:00 a.m
                                a 1:00
                                p.m y
                                de 2:00 p.m a 5:00 p.m. SABADOS de 8:00 a.m a 1:00 pm
                            </p>
                        </span>
                    </div>
                </t>
            </t>
        </template>

        <template id="report_purchaseorder">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="o">
                    <t t-call="campos_hoyos.report_purchaseorder_document"/>
                </t>
            </t>
        </template>

        <record id="purchase.action_report_purchase_order" model="ir.actions.report">
            <field name="name">Orden de comprar</field>
            <field name="model">purchase.order</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">campos_hoyos.report_purchaseorder</field>
            <field name="report_file">campos_hoyos.report_purchaseorder</field>
            <field name="print_report_name">
                (object.state in ('draft', 'sent') and 'Solicitud de cotización - %s' % (object.name) or
                'Orden de compra - %s' % (object.name))
            </field>
            <field name="binding_model_id" ref="purchase.model_purchase_order"/>
            <field name="binding_type">report</field>
        </record>


