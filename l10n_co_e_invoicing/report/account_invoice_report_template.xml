<odoo>
  <template id="report_invoice_document_custom" inherit_id="account.report_invoice_document">

  <xpath expr="//div[@id='informations']" position="before">

      <div class="row" style="font-size:13px; line-height:1.2;">

          <!-- Logo B4B -->
          <div class="col-2 text-center" t-if="o.b4b">
              <img src="/l10n_co_e_invoicing/static/description/imagen_b4b.jpeg"
                  style="max-width:100px; max-height:70px;"/>
          </div>

          <!-- Logo Servicio Logístico -->
          <div class="col-2 text-center" t-if="o.servicio_logistico">
              <img src="/l10n_co_e_invoicing/static/description/imagen_servilog.jpeg"
                  style="max-width:100px; max-height:70px;"/>
          </div>

          <!-- Notas Logísticas -->
          <div class="col-5" t-if="o.notas_logisticas">
              <strong>Notas Logísticas</strong><br/>
              <span t-field="o.notas_logisticas"/>
          </div>

          <!-- Asesor -->
          <div class="col-3" t-if="o.partner_id.user_id.name">
              <strong>Asesor</strong><br/>
              <span t-field="o.partner_id.user_id.name"/>
          </div>

      </div>

  </xpath>
  
    <xpath expr="//table[@name='invoice_line_table']/thead/tr" position="replace"> 
      <tr>
        <th class="text-center">#</th>
        <th class="text-center">Código Barras</th>
        <th class="text-center">Referencia</th>
        <th class="text-start">Descripción</th>
        <th class="text-end">Cantidad</th>
        <th class="text-end">P.Unit</th>
        <th class="text-center">IVA</th>
        <th class="text-end">P.Total</th>
      </tr>
      
    </xpath> 
    
    <xpath expr="//t[@name='account_invoice_line_accountable']" position="replace">

      <t t-if="line.display_type == 'product'" 
        name="account_invoice_line_accountable">

        <t t-set="net_price"
          t-value="line.price_unit * (1 - ((line.discount or 0) / 100.0))"/>

        <t t-set="iva_taxes" 
          t-value="line.tax_ids.filtered(lambda t: 'IVA' in (t.tax_group_id.name or '').upper())"/>

        <td class="text-center"> 
          <span t-esc="line_index + 1"/>
        </td>

        <td class="text-center">
          <t t-if="line.product_id.barcode">
            <img t-att-src="'/report/barcode/Code128/%s' % line.product_id.barcode" style="width:120px;height:25px;"/>
          </t> 
        </td>
        
        <td class="text-center">
          <span t-field="line.product_id.default_code"/>
        </td>
        
        <td>
          <span t-field="line.product_id.name"/>
        </td>
        
        <td class="text-end">
          <span t-field="line.quantity"/>
        </td>
        
        <td class="text-end">
          <span t-esc="net_price"
                t-options="{
                  'widget': 'monetary',
                  'display_currency': o.currency_id
                }"/>
        </td>
        
        <td class="text-center">
          <t t-foreach="iva_taxes" t-as="tax">
              <span t-esc="tax.amount"/>%
              <t t-if="not tax_last">
                  ,
              </t>
          </t>
        </td>
        
        <td class="text-end">
          <span t-esc="net_price * line.quantity"
                t-options="{
                  'widget': 'monetary',
                  'display_currency': o.currency_id
                }"/>
        </td>
      </t>
    </xpath>


    <xpath expr="//div[contains(@class, 'clearfix')]" position="inside">
      <t t-if="o.dian_document_lines">
        <t t-set="dian_doc" t-value="o.dian_document_lines[0]"/>
        <t t-set="sequence" t-value="o.move_type == 'out_refund' and o.journal_id.refund_sequence_id or o.journal_id.sequence_id"/>
        <t t-set="resolution_range" t-value="sequence.date_range_ids and sequence.date_range_ids[0] or False"/>

        <div class="mt-4" style="page-break-inside: avoid;">
          <div class="row">
            <!-- Columna izquierda: QR -->
            <div class="col-3 text-center">
              <t t-if="dian_doc.qr_code_dian_img">
                <img t-att-src="'data:image/png;base64,%s' % dian_doc.qr_code_dian_img" style="width:120px; height:120px;" />
              </t>
            </div>

            <!-- Columna derecha: Datos resolución -->
            <div class="col-9" style="font-size: 11px; line-height: 1.2;">
              <p style="margin: 0;"><strong style="font-size: 13px;">CUFE:</strong></p>
              <p style="margin: 0; word-break: break-word;"><span t-esc="dian_doc.cufe_cude"/></p>

              <t t-if="resolution_range">
                <p style="margin: 0;">
                  <strong>Número de autorización de facturación:</strong>
                  <span t-esc="resolution_range.resolution_number"/>
                  <strong>Fecha:</strong>
                  <span t-esc="resolution_range.date_from"/>
                </p>
                <p style="margin: 0;">
                  <strong>Rango autorizado desde:</strong>
                  <span t-esc="resolution_range.prefix"/> <span t-esc="resolution_range.number_from"/>
                  <strong>a:</strong>
                  <span t-esc="resolution_range.prefix"/> <span t-esc="resolution_range.number_to"/>
                  <strong>Válido desde:</strong>
                  <span t-esc="resolution_range.date_from"/>
                  <strong>Hasta:</strong>
                  <span t-esc="resolution_range.date_to"/>
                </p>
                <p style="margin: 0;">
                  <strong>Representación gráfica de facturación electrónica impresa por computador con software propio por:</strong>
                  <span t-esc="o.company_id.name"/>
                </p>
              <!-- Información adicional de la empresa -->
                <p style="margin: 0;"><strong>NIT:</strong><span t-esc="o.company_id.partner_id.identification_document or ''"/><t t-if="o.company_id.partner_id.check_digit">-<span t-esc="o.company_id.partner_id.check_digit"/></t></p>
                <p style="margin: 0;"><strong>Tipo de organización:</strong> Persona Juridica</p>
                <p style="margin: 0;"><strong>Tipo de régimen:</strong> Impuesto sobre las ventas – IVA</p>
                <p style="margin: 0;"><strong>Tipo de responsabilidad:</strong> No aplica – Otros</p>
                <p style="margin: 0;"><strong>Tipo de operación:</strong> Estandar</p>
              </t>
            </div>
          </div>
        </div>

        <!-- Información adicional de la factura -->
        <div class="row mt-3" style="font-size:14px; line-height:1.2;">

            <div class="col-3">
                <strong>Factura Número:</strong><br/>
                <span t-esc="o.name"/>
            </div>

            <div class="col-3">
                <strong>Plazo de Pago:</strong><br/>
                <t t-if="o.invoice_payment_term_id and o.invoice_payment_term_id.line_ids">
                    <span>Días </span>
                    <span t-esc="o.invoice_payment_term_id.line_ids[0].nb_days"/>
                </t>
            </div>

            <div class="col-3">
                <strong>Unidad de Empaque:</strong><br/>
                <span t-esc="o.packaging_order_observation or ''"/>
            </div>

            <div class="col-3">
                <strong>Fecha de Factura/Recibo:</strong><br/>
                <span t-field="o.create_date"/>
            </div>

        </div>
      </t>
    </xpath>
  </template>

  <template id="external_layout_striped_inherit_manifiesto"
            inherit_id="web.external_layout_striped">

      <xpath expr="//div[@class='text-center']/ul[@class='list-inline']"
            position="replace">

          <div class="row align-items-center">

              <!-- QR Manifiesto -->
              <div class="col-2 text-start"
                  t-if="o and o._name == 'account.move' and o.servicio_logistico">

                  <img src="/l10n_co_e_invoicing/static/description/imagen_manifiesto.jpeg"
                      style="width:180px;"/>

              </div>

              <!-- Footer empresa -->
              <div t-attf-class="{{ 'col-10' if o and o._name == 'account.move' and o.servicio_logistico else 'col-12' }}">

                  <ul class="list-inline mb-0">
                      <div t-field="company.report_footer"/>
                  </ul>

              </div>

          </div>

      </xpath>

  </template>
</odoo>