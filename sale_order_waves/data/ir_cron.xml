<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="ir_cron_auto_active_conductor" model="ir.cron">
            <field name="name">Planear ordenes de venta</field>
            <field name="interval_number">3</field>
            <field name="interval_type">minutes</field>
            <field name="numbercall">-1</field>
            <field name="nextcall" eval="DateTime.now()"/>
            <field name="doall" eval="False"/>
            <field name="active" eval="True"/>
            <field name="model_id" ref="model_stock_warehouse"/>
            <field name="code">env['stock.warehouse'].search([]).planear_automatico()</field>
            <field name="state">code</field>
        </record>
    </data>
</odoo>