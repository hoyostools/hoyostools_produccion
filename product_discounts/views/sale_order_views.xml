<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_order_form_inherit_discount_columns" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.discount.columns</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <!-- Insertar columnas en tree view de líneas -->
            <xpath expr="//field[@name='order_line']/tree/field[@name='price_unit']" position="before">
                <field name="descuento_1" optional="show"/>
                <field name="descuento_2" optional="show"/>
                <field name="descuento_3" optional="show"/>
            </xpath>
        </field>
    </record>
</odoo>
