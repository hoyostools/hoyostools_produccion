<odoo>
    <record id="res_users_view_journal" model="ir.ui.view">
        <field name="name">res_users_view_journal</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@class='oe_title']//field[@name='partner_id']" position="after">
                <field name="has_group_restriction" invisible="1"/>
                <field name="account_journal_ids" required="has_group_restriction" invisible="not has_group_restriction" widget="many2many_tags" options="{'no_create': True}"/>
            </xpath>
        </field>
    </record>
</odoo>