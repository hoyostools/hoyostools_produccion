<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <!-- FORM VIEW -->
        <record id="format_exogenus_view_form" model="ir.ui.view">
            <field name="name">format.exogenus.form</field>
            <field name="model">format.exogenus</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <h1>
                            <field name="name" placeholder="Formato" required="1"/>
                        </h1>

                        <group name="general_information_format">
                            <group col="2">
                                <field name="description_format"/>
                                <field name="code_format"/>
                                <field name="type_format"/>
                            </group>
                        </group>

                        <notebook>
                            <page name="columns" string="Columnas">
                                <field name="column_ids"/>
                            </page>

                            <page name="general_info" string="Información General">
                                <field name="general_id">
                                    <list string="Configuración" editable="top">
                                        <field name="concept_id"/>
                                        <field name="format_account_id"/>
                                        <field name="column_id"/>
                                        <field name="total_account"/>
                                        <field name="code_general" invisible="1"/>
                                        <field name="exogena_journal_ids" widget="many2many_tags"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- LIST VIEW -->
        <record id="format_exogenus_view_tree" model="ir.ui.view">
            <field name="name">format.exogenus.tree</field>
            <field name="model">format.exogenus</field>
            <field name="arch" type="xml">
                <list string="Format Exogenus">
                    <field name="name"/>
                    <field name="description_format"/>
                    <field name="code_format"/>
                </list>
            </field>
        </record>

        <!-- ACTION -->
        <record id="format_exogenus_action" model="ir.actions.act_window">
            <field name="name">Format Exogenus</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">format.exogenus</field>
            <field name="view_mode">list,form</field>
        </record>

        <!-- MENU ITEM -->
        <menuitem
            id="menu_format_exogenus_action"
            name="Formatos Exógena"
            parent="account.menu_finance_configuration"
            action="format_exogenus_action"
            sequence="10"
        />

    </data>
</odoo>
