<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="account_exogenus_view_tree" model="ir.ui.view">
            <field name="name">account.exogenus.view.tree</field>
            <field name="model">account.exogenus</field>
            <field name="arch" type="xml">
                <list editable="bottom" string="create" >
                    <field name="name"/>
                    <field name="account_id"/>
                    <field name="format_exogenus_account_id" invisible="1" />
                </list>
            </field>
        </record>
    </data>
    <record id="account_exogenus_action" model="ir.actions.act_window">
        <field name="name">Account Exogenus</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">account.exogenus</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="account_exogenus_view_tree"/>
        <field name="domain">[]</field>
        <field name="context">{}</field>
    </record> 

    <menuitem action="account_exogenus_action"
        id="menu_account_exogenus_action"
        parent="account.menu_finance_configuration"
        sequence="12"/>
</odoo>