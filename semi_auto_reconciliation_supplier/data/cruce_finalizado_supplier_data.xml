<odoo>

    <record id="seq_cruce_saldos_supplier" model="ir.sequence">
        <field name="name">Cruce Proveedores</field>
        <field name="code">cruce.saldos.supplier</field>
        <field name="prefix">CRUP/%(year)s/</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="journal_cruce_proveedores" model="account.journal">
        <field name="name">Cruce Proveedores</field>
        <field name="code">CRPR</field>
        <field name="type">bank</field>
        <field name="company_id" ref="base.main_company"/>
    </record>

</odoo>