<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

          <record id="campos_pagos_view_account_payment_form" model="ir.ui.view">
            <field name="name">campos.pagos.view.account.payment.form</field>
            <field name="model">account.payment</field>
            <field name="inherit_id" ref="account.view_account_payment_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='partner_id']" position="after">
                    <field name="vendor_id" invisible="partner_type != 'customer'" readonly="1" force_save="1"/>
                </xpath>
            </field>
        </record>

        <record id="campos_pagos_account_payment_tree" model="ir.ui.view">
            <field name="name">campos.pagos.account.payment.tree</field>
            <field name="model">account.payment</field>
            <field name="inherit_id" ref="account.view_account_payment_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='partner_id']" position="after">
                    <field name="vendor_id" optional="hide"/>
                </xpath>
            </field>
        </record>

    </data>
</odoo>